<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Naresh World Admin Panel</title>
    <!-- Fonts & Icons -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.2.1/css/all.min.css">
    <!-- Firebase -->
    <script src="https://www.gstatic.com/firebasejs/9.15.0/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.15.0/firebase-auth-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.15.0/firebase-database-compat.js"></script>
    <style>
        /* ========== GLOBAL STYLES ========== */
        :root {
            --primary-color: #e50914;
            --primary-hover: #f40612;
            --gradient: linear-gradient(90deg, #e50914 0%, #b80d14 100%);
            --bg-main: #000000;
            --bg-content: #0a0a0a;
            --bg-input: #1f1f1f;
            --border-color: #2a2a2a;
            --text-primary: #ffffff;
            --text-secondary: #b3b3b3;
            --sidebar-width: 260px;
            --success-color: #2e7d32;
            --warning-color: #f57c00;
            --premium-gold: #ffb700;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Poppins', sans-serif; }
        body { background-color: var(--bg-main); color: var(--text-primary); display: flex; }
        
        /* Sidebar */
        .sidebar {
            width: var(--sidebar-width);
            background-color: #000;
            height: 100vh;
            position: fixed;
            top: 0;
            left: 0;
            display: flex;
            flex-direction: column;
            border-right: 1px solid var(--border-color);
            z-index: 1100;
            transition: transform 0.3s ease-in-out;
        }
        .sidebar-header { text-align: center; padding: 25px 15px; margin-bottom: 20px; }
        .sidebar-header h1 { font-size: 24px; font-weight: 700; color: var(--primary-color); letter-spacing: 1px; }
        .nav-menu { list-style: none; padding: 0 15px; flex-grow: 1; overflow-y: auto; padding-bottom: 20px; }
        .nav-menu::-webkit-scrollbar { width: 5px; }
        .nav-menu::-webkit-scrollbar-thumb { background: #333; border-radius: 5px; }
        .nav-item a {
            display: flex; align-items: center; padding: 15px; color: var(--text-secondary);
            text-decoration: none; border-radius: 8px; margin-bottom: 10px;
            transition: background-color 0.3s, color 0.3s; font-weight: 500; position: relative;
        }
        .nav-item a:hover { background-color: var(--bg-input); color: var(--text-primary); }
        .nav-item a.active { background: var(--gradient); color: var(--text-primary); box-shadow: 0 4px 15px rgba(229, 9, 20, 0.3); }
        .nav-item a i { width: 30px; font-size: 18px; }
        .nav-badge {
            position: absolute; right: 15px; top: 50%; transform: translateY(-50%);
            background-color: var(--primary-color); color: white; width: 22px; height: 22px;
            border-radius: 50%; font-size: 12px; font-weight: 600;
            display: flex; align-items: center; justify-content: center;
            box-shadow: 0 0 10px rgba(229, 9, 20, 0.5);
        }

        /* Main Content */
        .main-content { margin-left: var(--sidebar-width); flex-grow: 1; padding: 30px; width: calc(100% - var(--sidebar-width)); }
        .main-header { display: none; }
        .mobile-logo { font-size: 22px; font-weight: 700; letter-spacing: 1px; margin-left: 15px; color: var(--text-primary); }
        .mobile-logo .text-primary { color: var(--primary-color); }
        
        /* Views */
        .view { display: none; }
        .view.active { display: block; animation: fadeIn 0.5s ease; }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
        .view-header {
            font-size: 32px; font-weight: 600; margin-bottom: 25px;
            padding-bottom: 10px; border-bottom: 1px solid var(--border-color);
        }
        
        /* Stats Grid */
        .stats-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 25px; }
        .stat-card {
            background-color: var(--bg-content); padding: 25px; border-radius: 12px;
            display: flex; align-items: center; gap: 20px; border: 1px solid var(--border-color);
            position: relative; overflow: hidden;
        }
        .stat-card.revenue { border-left: 4px solid #2e7d32; }
        .stat-card.revenue .stat-card-icon { color: #2e7d32; background: rgba(46, 125, 50, 0.1); }
        .stat-card.premium { border-left: 4px solid #f57c00; }
        .stat-card.premium .stat-card-icon { color: #f57c00; background: rgba(245, 124, 0, 0.1); }
        .stat-card-icon {
            font-size: 36px; color: var(--primary-color);
            background: rgba(229, 9, 20, 0.1); width: 70px; height: 70px;
            border-radius: 50%; display: flex; align-items: center; justify-content: center;
        }
        .stat-card-info h3 { font-size: 32px; font-weight: 700; }
        .stat-card-info p { font-size: 14px; color: var(--text-secondary); }

        /* Movie Grid */
        .movie-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 25px; }
        .movie-card {
            background-color: var(--bg-content); border-radius: 8px; overflow: hidden;
            position: relative; cursor: pointer; transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        .movie-card:hover { transform: scale(1.05); box-shadow: 0 8px 25px rgba(0,0,0,0.5); }
        .movie-card img { width: 100%; height: 300px; object-fit: cover; display: block; }
        .movie-card-overlay {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            background: linear-gradient(to top, rgba(0,0,0,0.9) 20%, transparent 60%);
            opacity: 0; transition: opacity 0.3s ease;
        }
        .movie-card:hover .movie-card-overlay { opacity: 1; }
        .movie-card-info { position: absolute; bottom: 10px; left: 10px; right: 10px; color: var(--text-primary); }
        .movie-card-info h3 { font-size: 16px; font-weight: 600; margin-bottom: 4px; }
        .movie-card-info p { font-size: 12px; color: var(--text-secondary); }
        .movie-card-actions {
            position: absolute; top: 10px; right: 10px; display: flex; gap: 8px;
            opacity: 0; transform: translateY(-10px); transition: opacity 0.3s ease, transform 0.3s ease;
        }
        .movie-card:hover .movie-card-actions { opacity: 1; transform: translateY(0); }
        .btn-icon {
            background: rgba(20, 20, 20, 0.7); border: 1px solid var(--border-color);
            color: var(--text-primary); width: 32px; height: 32px; border-radius: 50%;
            cursor: pointer; display: flex; justify-content: center; align-items: center;
            transition: background-color 0.2s;
        }
        .btn-icon:hover { background: var(--primary-color); }
        .btn-sm {
            padding: 8px 15px; font-size: 14px; font-weight: 500;
            background: var(--bg-input); color: var(--text-primary);
            border: 1px solid var(--border-color); border-radius: 6px;
            cursor: pointer; transition: all 0.2s ease;
        }
        .btn-sm:hover { background-color: var(--primary-color); border-color: var(--primary-color); }
        .btn-sm.ban-btn { background: #c62828; color: white; border-color: #c62828; }
        .btn-sm.ban-btn:hover { background: #b71c1c; }
        .btn-sm.unban-btn { background: #2e7d32; color: white; border-color: #2e7d32; }
        .btn-sm.unban-btn:hover { background: #1b5e20; }

        /* Forms */
        .form-container {
            max-width: 700px; background-color: var(--bg-content);
            padding: 30px; border-radius: 12px; border: 1px solid var(--border-color);
        }
        .form-group { margin-bottom: 20px; }
        .form-group label {
            display: flex; align-items: center; gap: 10px; margin-bottom: 8px;
            color: var(--text-secondary); font-size: 14px; font-weight: 500;
        }
        .form-group label i { color: var(--text-secondary); width: 16px; text-align: center; }
        .form-group input, .form-group select, .form-group textarea {
            width: 100%; padding: 12px; background-color: var(--bg-input);
            border: 1px solid var(--border-color); border-radius: 6px;
            color: var(--text-primary); font-size: 14px;
            transition: border-color 0.3s, box-shadow 0.3s;
        }
        .form-group input:focus, .form-group select:focus, .form-group textarea:focus {
            outline: none; border-color: var(--primary-color);
            box-shadow: 0 0 0 3px rgba(229, 9, 20, 0.2);
        }
        .form-group textarea { resize: vertical; min-height: 100px; }
        .category-checkbox-wrapper {
            display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
            gap: 10px; background: var(--bg-input); padding: 15px; border-radius: 6px;
            border: 1px solid var(--border-color); max-height: 200px; overflow-y: auto;
        }
        .category-checkbox-item {
            display: flex; align-items: center; gap: 8px; cursor: pointer; font-size: 13px;
        }
        .category-checkbox-item input { width: 16px; height: 16px; accent-color: var(--primary-color); }
        .btn {
            background: var(--gradient); color: white; border: none; padding: 14px 25px;
            border-radius: 6px; cursor: pointer; font-size: 16px; font-weight: 600;
            width: 100%; margin-top: 10px; transition: filter 0.3s;
        }
        .btn:hover { filter: brightness(1.1); }
        
        /* Cast Container */
        .cast-container {
            display: grid; grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
            gap: 15px; margin-top: 15px;
        }
        .cast-item {
            background-color: var(--bg-input); padding: 10px; border-radius: 8px;
            text-align: center; position: relative;
        }
        .cast-item img {
            width: 70px; height: 70px; border-radius: 50%; object-fit: cover;
            margin-bottom: 8px; border: 2px solid var(--border-color);
        }
        .cast-item p { font-size: 12px; color: var(--text-secondary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

        /* Live TV Grid */
        .livetv-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 25px; }
        .livetv-card {
            background-color: var(--bg-content); border-radius: 8px; padding: 15px;
            text-align: center; position: relative; border: 1px solid var(--border-color);
        }
        .livetv-card .logo-container {
            width: 100%; height: 90px; margin-bottom: 10px;
            display: flex; align-items: center; justify-content: center;
        }
        .livetv-card img { max-width: 100%; max-height: 100%; object-fit: contain; }
        .livetv-card h3 { font-size: 14px; font-weight: 500; color: var(--text-primary); }

        /* Category Management */
        .category-item {
            display: flex; justify-content: space-between; align-items: center;
            background-color: var(--bg-content); padding: 15px; border-radius: 8px;
            border: 1px solid var(--border-color); margin-bottom: 10px;
        }
        .category-item .view-mode, .category-item .edit-mode {
            display: flex; justify-content: space-between; align-items: center; width: 100%;
        }
        .category-item .actions { display: flex; gap: 10px; }
        .category-edit-input {
            padding: 8px; background-color: var(--bg-input); border: 1px solid var(--border-color);
            border-radius: 6px; color: var(--text-primary); font-size: 14px;
            flex-grow: 1; margin-right: 15px;
        }

        /* Tables */
        .table-container {
            background-color: var(--bg-content); border-radius: 12px;
            overflow-x: auto; border: 1px solid var(--border-color);
        }
        .styled-table { width: 100%; border-collapse: collapse; }
        .styled-table thead tr { background-color: var(--bg-input); text-align: left; font-weight: 600; }
        .styled-table th, .styled-table td { padding: 15px; white-space: nowrap; }
        .styled-table tbody tr { border-bottom: 1px solid var(--border-color); }
        .styled-table tbody tr:last-of-type { border-bottom: none; }
        .user-avatar {
            width: 40px; height: 40px; border-radius: 50%; background-color: var(--primary-color);
            display: flex; align-items: center; justify-content: center; font-weight: 600;
        }
        .banned-row { background-color: rgba(198, 40, 40, 0.1); }
        .banned-row td { color: #e57373; }
        .banned-badge {
            background: #c62828; color: white; padding: 2px 8px; border-radius: 4px;
            font-size: 10px; margin-left: 8px; vertical-align: middle;
        }

        /* Modal */
        .modal-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0, 0, 0, 0.8); backdrop-filter: blur(5px);
            display: none; justify-content: center; align-items: center; z-index: 1200;
        }
        .modal-content {
            background: var(--bg-content); padding: 20px; border-radius: 10px;
            width: 90%; max-width: 450px; max-height: 80vh; overflow-y: auto;
            border: 1px solid var(--border-color);
        }
        .modal-header {
            display: flex; justify-content: space-between; align-items: center;
            border-bottom: 1px solid var(--border-color); padding-bottom: 10px; margin-bottom: 15px;
        }
        .modal-close { background: none; border: none; color: var(--text-secondary); font-size: 24px; cursor: pointer; }

        /* Search Results */
        .search-result-item {
            display: flex; align-items: center; gap: 15px; padding: 10px;
            border-radius: 5px; cursor: pointer; transition: background-color 0.2s;
        }
        .search-result-item:hover { background-color: var(--bg-input); }
        .search-result-item img { width: 50px; height: 75px; object-fit: cover; border-radius: 4px; }
        .search-result-info h4 { color: var(--text-primary); font-size: 16px; }
        .search-result-info p { color: var(--text-secondary); font-size: 14px; }

        /* Season/Episode Blocks */
        .season-block {
            background: var(--bg-input); padding: 15px; border-radius: 8px;
            margin-bottom: 15px; border-left: 3px solid var(--primary-color);
        }
        .season-header { display: flex; align-items: center; gap: 15px; margin-bottom: 15px; }
        .season-header input { width: 100px; }
        .episode-block {
            background: var(--bg-main); padding: 15px; border-radius: 6px; margin-top: 10px;
            display: grid; grid-template-columns: 1fr 1fr; gap: 15px; position: relative;
        }
        .episode-block .form-group { margin-bottom: 0; }
        .episode-block .full-width { grid-column: 1 / -1; }
        .remove-btn {
            position: absolute; top: 10px; right: 10px; background: none;
            border: none; color: var(--text-secondary); font-size: 16px; cursor: pointer;
        }
        .remove-btn:hover { color: var(--primary-color); }

        /* Switch */
        .switch-container { display: flex; align-items: center; gap: 15px; }
        .switch { position: relative; display: inline-block; width: 60px; height: 34px; }
        .switch input { opacity: 0; width: 0; height: 0; }
        .slider {
            position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0;
            background-color: #333; transition: .4s; border-radius: 34px;
        }
        .slider:before {
            position: absolute; content: ""; height: 26px; width: 26px; left: 4px; bottom: 4px;
            background-color: white; transition: .4s; border-radius: 50%;
        }
        input:checked + .slider { background-color: var(--primary-color); }
        input:checked + .slider:before { transform: translateX(26px); }

        /* Premium / Plan Cards */
        .plan-card {
            background-color: var(--bg-content); border-radius: 8px; padding: 20px;
            border: 1px solid var(--border-color); position: relative; margin-bottom: 15px;
        }
        .plan-card h3 { color: var(--primary-color); margin-bottom: 10px; font-size: 20px; }
        .plan-card .price { font-size: 24px; font-weight: 700; color: #fff; margin-bottom: 10px; }
        .plan-card .details { font-size: 13px; color: var(--text-secondary); margin-bottom: 15px; }
        .plan-card .details span { display: block; margin-bottom: 5px; }
        .premium-check-label {
            color: #ffb700; font-weight: 600; cursor: pointer;
            display: flex; align-items: center; gap: 10px;
        }

        /* Ad Cards */
        .ad-card {
            background: var(--bg-content); border: 1px solid var(--border-color);
            border-radius: 8px; overflow: hidden; position: relative;
            display: flex; flex-direction: column;
        }
        .ad-preview {
            width: 100%; height: 180px; background: #000;
            display: flex; align-items: center; justify-content: center;
            overflow: hidden; position: relative;
        }
        .ad-preview img { width: 100%; height: 100%; object-fit: cover; }
        .ad-preview video { width: 100%; height: 100%; object-fit: contain; }
        .ad-type-badge {
            position: absolute; top: 10px; left: 10px; padding: 4px 8px;
            background: var(--primary-color); color: #fff; font-size: 10px;
            border-radius: 4px; font-weight: 600; z-index: 10;
        }
        .ad-content { padding: 15px; flex-grow: 1; }
        .ad-title { font-size: 16px; font-weight: 600; margin-bottom: 5px; }
        .ad-meta { font-size: 12px; color: var(--text-secondary); margin-bottom: 10px; display: flex; gap: 10px; }
        .ad-controls {
            padding: 15px; border-top: 1px solid var(--border-color);
            display: flex; justify-content: space-between; align-items: center;
            background: var(--bg-input);
        }

        /* Redeem Codes Table */
        .code-available { color: #2e7d32; font-weight: 600; }
        .code-used { color: #c62828; font-weight: 600; }
        .code-delete-btn {
            background: none; border: none; color: var(--text-secondary);
            font-size: 18px; cursor: pointer;
        }
        .code-delete-btn:hover { color: var(--primary-color); }

        /* Avatar Management */
        .avatar-management-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 30px; }
        .avatar-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(100px, 1fr)); gap: 15px; margin-top: 20px; }
        .avatar-card { position: relative; }
        .avatar-card img {
            width: 100%; aspect-ratio: 1/1; object-fit: cover;
            border-radius: 8px; border: 2px solid var(--border-color);
        }
        .avatar-card .delete-btn {
            position: absolute; top: 5px; right: 5px; opacity: 0;
            transform: scale(0.8); transition: all 0.2s ease-in-out;
        }
        .avatar-card:hover .delete-btn { opacity: 1; transform: scale(1); }

        /* Status Message */
        .status-message {
            padding: 12px; border-radius: 6px; text-align: center; font-weight: 500;
            position: fixed; top: 20px; right: 20px; z-index: 2000; min-width: 250px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.3);
        }
        .success { background-color: #2e7d32; color: white; }
        .error { background-color: #c62828; color: white; }

        /* Responsive */
        @media (max-width: 992px) {
            .sidebar { transform: translateX(-100%); }
            .sidebar.open { transform: translateX(0); }
            .main-content { margin-left: 0; width: 100%; padding: 15px; padding-top: 75px; }
            .main-header {
                display: flex; align-items: center; padding: 0 15px; height: 60px;
                background-color: #000; border-bottom: 1px solid var(--border-color);
                position: fixed; top: 0; left: 0; width: 100%; z-index: 1000;
            }
            #menu-toggle { background: none; border: none; color: var(--text-primary); font-size: 24px; cursor: pointer; }
            .view-header { font-size: 24px; }
        }
        @media (max-width: 600px) {
            .episode-block { grid-template-columns: 1fr; }
            .avatar-management-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <h1>Naresh World</h1>
        </div>
        <ul class="nav-menu">
            <li class="nav-item"><a href="#" id="nav-dashboard" class="active" onclick="showView('dashboard-view')"><i class="fa-solid fa-table-columns"></i><span>Analytics & Dashboard</span></a></li>
            <li class="nav-item"><a href="#" id="nav-manage-movies" onclick="showView('manage-movies-view')"><i class="fa-solid fa-film"></i><span>Manage Movies</span></a></li>
            <li class="nav-item"><a href="#" id="nav-add-movie" onclick="showView('add-movie-view')"><i class="fa-solid fa-plus"></i><span>Add Movie</span></a></li>
            <li class="nav-item"><a href="#" id="nav-manage-series" onclick="showView('manage-series-view')"><i class="fa-solid fa-layer-group"></i><span>Manage Series</span></a></li>
            <li class="nav-item"><a href="#" id="nav-add-series" onclick="showView('add-series-view')"><i class="fa-solid fa-plus-square"></i><span>Add Series</span></a></li>
            <!-- ===== SHORTS TV MENU ITEMS ===== -->
            <li class="nav-item"><a href="#" id="nav-manage-shorts" onclick="showView('manage-shorts-view')"><i class="fa-solid fa-clapperboard"></i><span>Manage Shorts</span></a></li>
            <li class="nav-item"><a href="#" id="nav-add-short" onclick="showView('add-short-view')"><i class="fa-solid fa-square-plus"></i><span>Add Short</span></a></li>
            <!-- ===== END SHORTS TV ===== -->
            <li class="nav-item"><a href="#" id="nav-manage-categories" onclick="showView('manage-categories-view')"><i class="fa-solid fa-tags"></i><span>Manage Categories</span></a></li>
            <li class="nav-item"><a href="#" id="nav-manage-livetv" onclick="showView('manage-livetv-view')"><i class="fa-solid fa-tv"></i><span>Manage Live TV</span></a></li>
            <li class="nav-item"><a href="#" id="nav-add-livetv" onclick="showView('add-livetv-view')"><i class="fa-solid fa-plus-circle"></i><span>Add Live TV</span></a></li>
            <li class="nav-item"><a href="#" id="nav-manage-ads" onclick="showView('manage-ads-view')"><i class="fa-solid fa-bullhorn"></i><span>Manage Ads</span></a></li>
            <li class="nav-item"><a href="#" id="nav-manage-plans" onclick="showView('manage-plans-view')"><i class="fa-solid fa-crown"></i><span>Manage Plans</span></a></li>
            <li class="nav-item"><a href="#" id="nav-payment-settings" onclick="showView('payment-settings-view')"><i class="fa-solid fa-qrcode"></i><span>Payment Settings</span></a></li>
            <li class="nav-item">
                <a href="#" id="nav-premium-requests" onclick="showView('premium-requests-view')">
                    <i class="fa-solid fa-money-bill"></i><span>Premium Requests</span>
                    <span class="nav-badge" id="premium-badge" style="display: none;">0</span>
                </a>
            </li>
            <li class="nav-item"><a href="#" id="nav-manual-premium" onclick="showView('manual-premium-view')"><i class="fa-solid fa-user-plus"></i><span>Assign Premium</span></a></li>
            <li class="nav-item"><a href="#" id="nav-redeem-codes" onclick="showView('redeem-codes-view')"><i class="fa-solid fa-ticket"></i><span>Redeem Codes</span></a></li>
            <li class="nav-item"><a href="#" id="nav-users" onclick="showView('users-view')"><i class="fa-solid fa-users"></i><span>Users & Ban System</span></a></li>
            <li class="nav-item">
                <a href="#" id="nav-movie-requests" onclick="showView('movie-requests-view')">
                    <i class="fa-solid fa-inbox"></i><span>Movie Requests</span>
                    <span class="nav-badge" id="requests-badge" style="display: none;">0</span>
                </a>
            </li>
            <li class="nav-item"><a href="#" id="nav-send-notification" onclick="showView('send-notification-view')"><i class="fa-solid fa-paper-plane"></i><span>Send Notification</span></a></li>
            <li class="nav-item"><a href="#" id="nav-manage-avatars" onclick="showView('manage-avatars-view')"><i class="fa-solid fa-user-circle"></i><span>Manage Avatars</span></a></li>
            <li class="nav-item"><a href="#" id="nav-app-control" onclick="showView('app-control-view')"><i class="fa-solid fa-gears"></i><span>App Control</span></a></li>
            <li class="nav-item"><a href="#" id="nav-maintenance" onclick="showView('maintenance-view')"><i class="fa-solid fa-screwdriver-wrench"></i><span>Maintenance Mode</span></a></li>
        </ul>
    </aside>

    <!-- Main Content -->
    <main class="main-content">
        <header class="main-header">
            <button id="menu-toggle"><i class="fa-solid fa-bars"></i></button>
            <h1 class="mobile-logo">NARESH<span class="text-primary">WORLD</span></h1>
        </header>
        <div id="status-message" class="status-message" style="display: none;"></div>

        <!-- Dashboard View -->
        <section id="dashboard-view" class="view active">
            <h2 class="view-header">Analytics Dashboard</h2>
            <div class="stats-grid">
                <div class="stat-card"><div class="stat-card-icon"><i class="fa-solid fa-ticket"></i></div><div class="stat-card-info"><h3 id="total-movies-stat">0</h3><p>Total Movies</p></div></div>
                <div class="stat-card"><div class="stat-card-icon"><i class="fa-solid fa-layer-group"></i></div><div class="stat-card-info"><h3 id="total-series-stat">0</h3><p>Total Series</p></div></div>
                <div class="stat-card"><div class="stat-card-icon"><i class="fa-solid fa-clapperboard"></i></div><div class="stat-card-info"><h3 id="total-shorts-stat">0</h3><p>Total Shorts</p></div></div>
                <div class="stat-card"><div class="stat-card-icon"><i class="fa-solid fa-user-check"></i></div><div class="stat-card-info"><h3 id="total-users-stat">0</h3><p>Total Users</p></div></div>
                <div class="stat-card premium"><div class="stat-card-icon"><i class="fa-solid fa-crown"></i></div><div class="stat-card-info"><h3 id="total-vip-stat">0</h3><p>Active VIP Users</p></div></div>
                <div class="stat-card revenue"><div class="stat-card-icon"><i class="fa-solid fa-chart-line"></i></div><div class="stat-card-info"><h3 id="total-revenue-stat">$0</h3><p>Total Revenue (Est.)</p></div></div>
                <div class="stat-card"><div class="stat-card-icon"><i class="fa-solid fa-satellite-dish"></i></div><div class="stat-card-info"><h3 id="total-livetv-stat">0</h3><p>Live Channels</p></div></div>
            </div>
        </section>

        <!-- Manage Movies View -->
        <section id="manage-movies-view" class="view">
            <h2 class="view-header">Manage Movies</h2>
            <div id="movie-grid-container" class="movie-grid"></div>
        </section>

        <!-- Add/Edit Movie View -->
        <section id="add-movie-view" class="view">
            <h2 class="view-header" id="movie-form-title">Add New Movie</h2>
            <div class="form-container">
                <input type="hidden" id="movie-edit-id">
                <div class="form-group"><label><i class="fa-solid fa-magnifying-glass"></i> TMDB Search (Movie)</label><input type="text" id="movie-tmdb-search" placeholder="Search by Name or enter TMDB ID"><button class="btn" style="margin-top:10px;" onclick="searchTmdb('movie')">Search Movie</button></div>
                <div class="form-group"><label><i class="fa-solid fa-heading"></i> Title</label><input type="text" id="movie-title"></div>
                <div class="form-group"><label><i class="fa-solid fa-image"></i> Poster URL</label><input type="text" id="movie-poster"></div>
                <div class="form-group"><label><i class="fa-solid fa-panorama"></i> Backdrop URL</label><input type="text" id="movie-backdrop"></div>
                <div class="form-group"><label><i class="fa-solid fa-star"></i> Rating</label><input type="text" id="movie-rating"></div>
                <div class="form-group"><label><i class="fa-solid fa-calendar-days"></i> Year</label><input type="number" id="movie-year"></div>
                <div class="form-group"><label><i class="fa-solid fa-pen-to-square"></i> Storyline</label><textarea id="movie-storyline"></textarea></div>
                <div class="form-group">
                    <label><i class="fa-solid fa-folder-open"></i> Categories (Select Multiple)</label>
                    <div id="movie-category-wrapper" class="category-checkbox-wrapper">
                        <p style="color: var(--text-secondary); font-size:12px;">Loading categories...</p>
                    </div>
                </div>
                <div class="form-group">
                    <label><i class="fa-solid fa-certificate"></i> Quality Badge</label>
                    <select id="movie-quality-badge">
                        <option value="none">None</option><option value="HD">HD</option><option value="WEB-DL">WEB-DL</option>
                    </select>
                </div>
                <div class="form-group" style="display: flex; gap: 20px;">
                    <label style="cursor: pointer; width: auto;"><input type="checkbox" id="movie-is-new" style="width: auto; height: 16px; margin-right: 10px;"> Mark as 'New'</label>
                    <label class="premium-check-label"><input type="checkbox" id="movie-is-premium" style="width: auto; height: 16px; margin-right: 10px;"> <i class="fa-solid fa-lock"></i> Premium (VIP Only)</label>
                </div>
                <hr>
                <div class="form-group"><label><i class="fa-solid fa-users"></i> Cast</label><div id="movie-cast-container" class="cast-container"></div></div>
                <hr>
                <div class="form-group"><label><i class="fa-solid fa-link"></i> Movie Stream Link</label><input type="text" id="movie-link"></div>
                <button class="btn" id="save-movie-btn" onclick="handleSaveMovie()">Save Movie</button>
            </div>
        </section>

        <!-- Manage Series View -->
        <section id="manage-series-view" class="view">
            <h2 class="view-header">Manage Series</h2>
            <div id="series-grid-container" class="movie-grid"></div>
        </section>

        <!-- Add/Edit Series View -->
        <section id="add-series-view" class="view">
            <h2 class="view-header" id="series-form-title">Add New Series</h2>
            <div class="form-container">
                <input type="hidden" id="series-edit-id">
                <div class="form-group"><label><i class="fa-solid fa-magnifying-glass"></i> TMDB Search (TV Show)</label><input type="text" id="series-tmdb-search" placeholder="Search by Name or enter TMDB ID"><button class="btn" style="margin-top:10px;" onclick="searchTmdb('tv')">Search TV Show</button></div>
                <div class="form-group"><label><i class="fa-solid fa-heading"></i> Title</label><input type="text" id="series-title"></div>
                <div class="form-group"><label><i class="fa-solid fa-image"></i> Poster URL</label><input type="text" id="series-poster"></div>
                <div class="form-group"><label><i class="fa-solid fa-panorama"></i> Backdrop URL</label><input type="text" id="series-backdrop"></div>
                <div class="form-group"><label><i class="fa-solid fa-star"></i> Rating</label><input type="text" id="series-rating"></div>
                <div class="form-group"><label><i class="fa-solid fa-calendar-days"></i> Year</label><input type="number" id="series-year"></div>
                <div class="form-group"><label><i class="fa-solid fa-pen-to-square"></i> Storyline</label><textarea id="series-storyline"></textarea></div>
                <div class="form-group">
                    <label><i class="fa-solid fa-folder-open"></i> Categories (Select Multiple)</label>
                    <div id="series-category-wrapper" class="category-checkbox-wrapper">
                        <p style="color: var(--text-secondary); font-size:12px;">Loading categories...</p>
                    </div>
                </div>
                <div class="form-group">
                    <label><i class="fa-solid fa-certificate"></i> Quality Badge</label>
                    <select id="series-quality-badge">
                        <option value="none">None</option><option value="HD">HD</option><option value="WEB-DL">WEB-DL</option>
                    </select>
                </div>
                <div class="form-group" style="display: flex; gap: 20px;">
                    <label style="cursor: pointer; width: auto;"><input type="checkbox" id="series-is-new" style="width: auto; height: 16px; margin-right: 10px;"> Mark as 'New'</label>
                    <label class="premium-check-label"><input type="checkbox" id="series-is-premium" style="width: auto; height: 16px; margin-right: 10px;"> <i class="fa-solid fa-lock"></i> Premium Series (VIP)</label>
                </div>
                <hr>
                <div class="form-group"><label><i class="fa-solid fa-users"></i> Cast</label><div id="series-cast-container" class="cast-container"></div></div>
                <hr>
                <div class="form-group">
                    <label style="justify-content: space-between;"><span><i class="fa-solid fa-list-ol"></i> Seasons & Episodes</span> <button type="button" class="btn-sm" onclick="addSeason()">+ Add Season</button></label>
                    <div id="series-seasons-container"></div>
                </div>
                <button class="btn" id="save-series-btn" onclick="handleSaveSeries()">Save Series</button>
            </div>
        </section>

        <!-- ===== MANAGE SHORTS VIEW ===== -->
        <section id="manage-shorts-view" class="view">
            <h2 class="view-header">Manage Shorts</h2>
            <div id="shorts-grid-container" class="movie-grid"></div>
        </section>

        <!-- ===== ADD/EDIT SHORT VIEW ===== -->
        <section id="add-short-view" class="view">
            <h2 class="view-header" id="short-form-title">Add New Short</h2>
            <div class="form-container">
                <input type="hidden" id="short-edit-id">
                <div class="form-group"><label><i class="fa-solid fa-heading"></i> Title</label><input type="text" id="short-title" placeholder="e.g., Funny Cat Compilation"></div>
                <div class="form-group"><label><i class="fa-solid fa-align-left"></i> Description</label><textarea id="short-description" placeholder="Short description..."></textarea></div>
                <div class="form-group"><label><i class="fa-solid fa-video"></i> Video URL (MP4 recommended)</label><input type="text" id="short-video-url" placeholder="https://.../short.mp4"></div>
                <div class="form-group"><label><i class="fa-solid fa-image"></i> Thumbnail URL</label><input type="text" id="short-thumbnail" placeholder="https://.../thumb.jpg"></div>
                <div class="form-group">
                    <label><i class="fa-solid fa-folder-open"></i> Categories (Select Multiple)</label>
                    <div id="short-category-wrapper" class="category-checkbox-wrapper">
                        <p style="color: var(--text-secondary); font-size:12px;">Loading categories...</p>
                    </div>
                </div>
                <div class="form-group" style="display: flex; gap: 20px;">
                    <label style="cursor: pointer; width: auto;"><input type="checkbox" id="short-is-new" style="width: auto; height: 16px; margin-right: 10px;"> Mark as 'New'</label>
                    <label class="premium-check-label"><input type="checkbox" id="short-is-premium" style="width: auto; height: 16px; margin-right: 10px;"> <i class="fa-solid fa-lock"></i> Premium (VIP Only)</label>
                </div>
                <button class="btn" id="save-short-btn" onclick="handleSaveShort()">Save Short</button>
            </div>
        </section>
        <!-- ===== END SHORTS VIEWS ===== -->

        <!-- Manage Categories View -->
        <section id="manage-categories-view" class="view">
            <h2 class="view-header">Manage Categories</h2>
            <div class="form-container" style="max-width: 500px; margin-bottom: 30px;">
                <div class="form-group"><label><i class="fa-solid fa-plus"></i> Add New Category</label><input type="text" id="category-name" placeholder="e.g., Hollywood"></div>
                <button class="btn" onclick="handleSaveCategory()">Save Category</button>
            </div>
            <div id="category-list-container"></div>
        </section>

        <!-- Manage Live TV View -->
        <section id="manage-livetv-view" class="view">
            <h2 class="view-header">Manage Live TV</h2>
            <div id="livetv-grid-container" class="livetv-grid"></div>
        </section>

        <!-- Add Live TV View -->
        <section id="add-livetv-view" class="view">
            <h2 class="view-header" id="livetv-form-title">Add New Live TV Channel</h2>
            <div class="form-container">
                <input type="hidden" id="livetv-edit-id">
                <div class="form-group"><label><i class="fa-solid fa-heading"></i> Channel Name</label><input type="text" id="livetv-name"></div>
                <div class="form-group"><label><i class="fa-solid fa-image"></i> Logo URL</label><input type="text" id="livetv-logo"></div>
                <div class="form-group"><label><i class="fa-solid fa-link"></i> Stream URL</label><input type="text" id="livetv-stream"></div>
                <div class="form-group">
                    <label><i class="fa-solid fa-folder-open"></i> Category</label>
                    <select id="livetv-category">
                        <option value="Entertainment">Entertainment</option><option value="News">News</option>
                        <option value="Sports">Sports</option><option value="Kids & Cartoon">Kids & Cartoon</option>
                        <option value="Music">Music</option><option value="Movies">Movies</option><option value="TV Show">TV Show</option>
                    </select>
                </div>
                <button class="btn" id="save-livetv-btn" onclick="handleSaveLiveTv()">Save Channel</button>
            </div>
        </section>

        <!-- Manage Ads View -->
        <section id="manage-ads-view" class="view">
            <h2 class="view-header">Manage Advertisements</h2>
            <div class="form-container">
                <h3 style="margin-bottom: 15px;">Create New Ad</h3>
                <input type="hidden" id="ad-edit-id">
                <div class="form-group"><label><i class="fa-solid fa-heading"></i> Ad Title (Internal Use)</label><input type="text" id="ad-title" placeholder="e.g., Betting App Promo 1"></div>
                <div class="form-group"><label><i class="fa-solid fa-layer-group"></i> Ad Type</label><select id="ad-type"><option value="image">Image Banner (Full Screen)</option><option value="video">Video Ad</option></select></div>
                <div class="form-group"><label><i class="fa-solid fa-image"></i> Media URL (Image or Video Link)</label><input type="text" id="ad-media-url" placeholder="https://.../ad.jpg OR https://.../ad.mp4"></div>
                <div class="form-group"><label><i class="fa-solid fa-link"></i> Click Target URL</label><input type="text" id="ad-target-url" placeholder="https://website.com"></div>
                <div class="form-group"><label><i class="fa-solid fa-clock"></i> Duration (Seconds)</label><input type="number" id="ad-duration" placeholder="e.g. 5, 10, 30" value="5"></div>
                <div class="form-group"><label style="cursor: pointer; width: auto;"><input type="checkbox" id="ad-is-active" style="width: auto; height: 16px; margin-right: 10px;" checked> Enable Immediately</label></div>
                <button class="btn" id="save-ad-btn" onclick="handleSaveAd()">Save Advertisement</button>
            </div>
            <hr>
            <h3 style="margin-bottom: 20px;">Active Advertisement Leads</h3>
            <div id="ads-grid-container" class="movie-grid"></div>
        </section>

        <!-- Manage Premium Plans View -->
        <section id="manage-plans-view" class="view">
            <h2 class="view-header">Manage Premium Plans</h2>
            <div class="form-container">
                <div class="form-group"><label><i class="fa-solid fa-tag"></i> Plan Name</label><input type="text" id="plan-name" placeholder="e.g., Monthly VIP"></div>
                <div class="form-group"><label><i class="fa-solid fa-money-bill-wave"></i> Price</label><input type="text" id="plan-price" placeholder="e.g., $9.99 or 999 INR"></div>
                <div class="form-group"><label><i class="fa-solid fa-calendar"></i> Duration (Days)</label><input type="number" id="plan-days" placeholder="e.g., 30"></div>
                <div class="form-group"><label><i class="fa-solid fa-mobile-screen"></i> Device Limit</label><input type="number" id="plan-devices" placeholder="e.g., 2"></div>
                <div class="form-group"><label><i class="fa-solid fa-info-circle"></i> Description</label><textarea id="plan-desc" placeholder="Details about the plan (e.g., 4K Quality, No Ads)"></textarea></div>
                <button class="btn" onclick="savePlan()">Add Plan</button>
            </div>
            <hr>
            <h3 style="margin-bottom: 20px;">Active Plans</h3>
            <div id="plans-list-container" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 20px;"></div>
        </section>

        <!-- Payment Settings View -->
        <section id="payment-settings-view" class="view">
            <h2 class="view-header">Payment Settings</h2>
            <div class="form-container">
                <p style="color: var(--text-secondary); margin-bottom: 20px;">Set up your UPI ID and QR Code so users know where to send payments.</p>
                <div class="form-group"><label><i class="fa-solid fa-mobile-button"></i> UPI ID (UPI Number/Address)</label><input type="text" id="payment-upi-id" placeholder="e.g., merchant@upi or 9876543210@ybl"></div>
                <div class="form-group"><label><i class="fa-solid fa-qrcode"></i> QR Code Image URL</label><input type="text" id="payment-qr-code" placeholder="https://.../qrcode.jpg"><small style="color: var(--text-secondary);">Upload your QR code image to a host and paste the link here.</small></div>
                <div id="qr-preview" style="margin-top: 15px; text-align: center; display: none;"><p>Preview:</p><img id="qr-preview-img" src="" style="width: 200px; height: 200px; object-fit: contain; border: 2px solid var(--border-color); border-radius: 8px;"></div>
                <button class="btn" onclick="savePaymentDetails()">Save Payment Details</button>
            </div>
        </section>

        <!-- Premium Requests View -->
        <section id="premium-requests-view" class="view">
            <h2 class="view-header">Premium Requests (UTR)</h2>
            <div class="table-container">
                <table class="styled-table">
                    <thead><tr><th>User Email</th><th>Plan Name</th><th>UTR Number</th><th>Date</th><th>Actions</th></tr></thead>
                    <tbody id="premium-requests-body"></tbody>
                </table>
            </div>
        </section>

        <!-- Manual Premium Assign View -->
        <section id="manual-premium-view" class="view">
            <h2 class="view-header">Assign Premium Manually</h2>
            <div class="form-container">
                <p style="margin-bottom: 20px; color: var(--text-secondary);">Directly grant premium access to a user by their User ID (UID).</p>
                <div class="form-group"><label><i class="fa-solid fa-id-badge"></i> User ID (UID)</label><input type="text" id="manual-uid" placeholder="Enter User UID from Users table"></div>
                <div class="form-group"><label><i class="fa-solid fa-clock"></i> Duration (Days)</label><input type="number" id="manual-days" placeholder="e.g., 365"></div>
                <button class="btn" onclick="handleManualPremium()">Grant Premium</button>
            </div>
        </section>

        <!-- Redeem Codes View (ENHANCED with Expiry & Max Uses) -->
        <section id="redeem-codes-view" class="view">
            <h2 class="view-header">Redeem Codes</h2>
            <div class="form-container" style="max-width: 600px; margin-bottom: 30px;">
                <h3 style="margin-bottom: 15px;">Generate New Codes</h3>
                <div class="form-group">
                    <label><i class="fa-solid fa-calendar"></i> Days of Premium</label>
                    <input type="number" id="redeem-days" placeholder="e.g., 30" min="1" required>
                </div>
                <div class="form-group">
                    <label><i class="fa-solid fa-money-bill"></i> Plan Price (Value)</label>
                    <input type="text" id="redeem-price" placeholder="e.g., $5 or 500" required>
                </div>
                <div class="form-group">
                    <label><i class="fa-solid fa-calendar-xmark"></i> Expiry Date (Optional)</label>
                    <input type="date" id="redeem-expiry">
                </div>
                <div class="form-group">
                    <label><i class="fa-solid fa-repeat"></i> Max Uses (default 1)</label>
                    <input type="number" id="redeem-max-uses" min="1" value="1">
                </div>
                <div class="form-group">
                    <label><i class="fa-solid fa-copy"></i> Number of Codes</label>
                    <input type="number" id="redeem-count" placeholder="e.g., 10" min="1" max="50" value="1" required>
                </div>
                <button class="btn" onclick="generateRedeemCodes()">Generate Codes</button>
            </div>
            <hr>
            <h3 style="margin-bottom: 20px;">Existing Codes</h3>
            <div class="table-container">
                <table class="styled-table">
                    <thead>
                        <tr>
                            <th>Code</th>
                            <th>Days</th>
                            <th>Price</th>
                            <th>Status</th>
                            <th>Used/Uses</th>
                            <th>Expiry</th>
                            <th>Used By</th>
                            <th>Used At</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="redeem-codes-body">
                        <tr><td colspan="9" style="text-align: center;">Loading codes...</td></tr>
                    </tbody>
                </table>
            </div>
        </section>

        <!-- Users & Ban System View -->
        <section id="users-view" class="view">
            <h2 class="view-header">Manage Users & Bans</h2>
            <div class="table-container">
                <table class="styled-table">
                    <thead><tr><th>User</th><th>Email</th><th>User ID</th><th>Status</th><th>Actions</th></tr></thead>
                    <tbody id="user-list-body"></tbody>
                </table>
            </div>
        </section>

        <!-- Movie Requests View -->
        <section id="movie-requests-view" class="view">
            <h2 class="view-header">Movie Requests</h2>
            <div class="table-container">
                <table class="styled-table">
                    <thead><tr><th>Movie Title</th><th>Year</th><th>Requested By</th><th>Date</th><th>Actions</th></tr></thead>
                    <tbody id="request-list-body"></tbody>
                </table>
            </div>
        </section>

        <!-- Send Notification View -->
        <section id="send-notification-view" class="view">
            <h2 class="view-header">Send Notification</h2>
            <div class="form-container">
                <input type="hidden" id="notif-movie-id"><input type="hidden" id="notif-movie-poster">
                <div class="form-group"><label><i class="fa-solid fa-pen"></i> Notification Title</label><input type="text" id="notif-title" placeholder="e.g., New Movie Added!"></div>
                <div class="form-group"><label><i class="fa-solid fa-comment-dots"></i> Message</label><textarea id="notif-message" placeholder="Describe the notification..."></textarea></div>
                <div class="form-group"><label><i class="fa-solid fa-icons"></i> Icon</label><select id="notif-icon"><option value="fa-fire">Trending (Fire)</option><option value="fa-plus-circle">New Addition (Plus)</option><option value="fa-tv">Live TV (TV)</option><option value="fa-bell">General (Bell)</option><option value="fa-check-circle">Completed (Check)</option></select></div>
                <hr>
                <div class="form-group"><label><i class="fa-solid fa-link"></i> Attach Movie (Optional)</label><input type="text" id="notif-movie-search" placeholder="Search for a movie in your database..."><div id="notif-movie-search-results" style="margin-top: 10px;"></div><div id="notif-movie-preview" style="display: none;"></div></div>
                <hr>
                <div class="form-group"><label><i class="fa-solid fa-bullseye"></i> Target Users</label><div class="radio-group"><label><input type="radio" name="target" value="all" checked onchange="toggleEmailTarget(false)"> All Users</label><label><input type="radio" name="target" value="specific" onchange="toggleEmailTarget(true)"> Specific Users</label></div></div>
                <div class="form-group" id="email-target-container" style="display: none;"><label><i class="fa-solid fa-at"></i> User Emails</label><textarea id="notif-emails" placeholder="Enter comma-separated email addresses"></textarea></div>
                <button class="btn" onclick="handleSendNotification()">Send Notification</button>
            </div>
        </section>

        <!-- Manage Avatars View -->
        <section id="manage-avatars-view" class="view">
            <h2 class="view-header">Manage User Avatars</h2>
            <p style="color: var(--text-secondary); margin-top: -20px; margin-bottom: 25px;">Add or remove avatars that users can select for their profiles.</p>
            <div class="avatar-management-grid">
                <div class="form-container">
                    <h3 style="margin-bottom: 15px;">Male Avatars</h3>
                    <div class="form-group"><label><i class="fa-solid fa-plus"></i> Add New Male Avatar URL</label><input type="text" id="male-avatar-url" placeholder="https://i.ibb.co/.../avatar.jpg"></div>
                    <button class="btn" onclick="addAvatar('male')">Add Male Avatar</button>
                    <hr>
                    <div id="male-avatars-grid" class="avatar-grid"><p style="color: var(--text-secondary); grid-column: 1 / -1;">Loading avatars...</p></div>
                </div>
                <div class="form-container">
                    <h3 style="margin-bottom: 15px;">Female Avatars</h3>
                    <div class="form-group"><label><i class="fa-solid fa-plus"></i> Add New Female Avatar URL</label><input type="text" id="female-avatar-url" placeholder="https://i.ibb.co/.../avatar.jpg"></div>
                    <button class="btn" onclick="addAvatar('female')">Add Female Avatar</button>
                    <hr>
                    <div id="female-avatars-grid" class="avatar-grid"><p style="color: var(--text-secondary); grid-column: 1 / -1;">Loading avatars...</p></div>
                </div>
            </div>
        </section>

        <!-- App Control View -->
        <section id="app-control-view" class="view">
            <h2 class="view-header">App Version Control</h2>
            <div class="form-container">
                <p style="color: var(--text-secondary); margin-bottom: 20px;">Manage app updates. If "Force Update" is enabled, users cannot use the app without updating.</p>
                <div class="form-group"><label><i class="fa-solid fa-code-branch"></i> Version Code (Integer)</label><input type="number" id="app-ver-code" placeholder="e.g., 10"></div>
                <div class="form-group"><label><i class="fa-solid fa-tag"></i> Version Name (String)</label><input type="text" id="app-ver-name" placeholder="e.g., v2.1.0"></div>
                <div class="form-group"><label style="cursor: pointer; width: auto;"><input type="checkbox" id="app-force-update" style="width: auto; height: 16px; margin-right: 10px;"> Force Update Required</label></div>
                <div class="form-group"><label><i class="fa-solid fa-link"></i> APK Download URL</label><input type="text" id="app-apk-url" placeholder="https://.../app-release.apk"></div>
                <div class="form-group"><label><i class="fa-solid fa-clipboard-list"></i> What's New (Changelog)</label><textarea id="app-changelog" placeholder="- Fixed bugs&#10;- Added new features"></textarea></div>
                <button class="btn" onclick="saveAppControlSettings()">Update App Settings</button>
            </div>
        </section>

        <!-- Maintenance Mode View -->
        <section id="maintenance-view" class="view">
            <h2 class="view-header">App Maintenance Mode</h2>
            <div class="form-container" style="max-width: 600px;">
                <div class="form-group">
                    <label><i class="fa-solid fa-power-off"></i> Enable Maintenance Mode</label>
                    <div class="switch-container">
                        <label class="switch"><input type="checkbox" id="maintenance-toggle"><span class="slider"></span></label>
                        <span id="maintenance-status-text" style="font-weight: 600; color: var(--text-secondary);">App is LIVE</span>
                    </div>
                </div>
                <div class="form-group"><label for="maintenance-message"><i class="fa-solid fa-envelope-open-text"></i> Maintenance Message</label><textarea id="maintenance-message" placeholder="e.g., The app is currently under maintenance. We will be back shortly."></textarea></div>
                <button class="btn" onclick="handleSaveMaintenance()">Save Settings</button>
            </div>
        </section>
    </main>

    <!-- Search Modal -->
    <div class="modal-overlay" id="search-modal">
        <div class="modal-content">
            <div class="modal-header"><h3>Select from Results</h3><button class="modal-close" onclick="closeSearchModal()">&times;</button></div>
            <div id="search-results-container"></div>
        </div>
    </div>

    <script>
        // ========== FIREBASE CONFIG ==========
        const firebaseConfig = {
            apiKey: "AIzaSyDH7d_mfsUJgHIMDxi3p1MjGOHR0t_T6NA",
            authDomain: "app-seller-8980c.firebaseapp.com",
            databaseURL: "https://app-seller-8980c-default-rtdb.firebaseio.com",
            projectId: "app-seller-8980c",
            storageBucket: "app-seller-8980c.firebasestorage.app",
            messagingSenderId: "275124357254",
            appId: "1:275124357254:web:63cc537b62f76e67f92907"
        };
        firebase.initializeApp(firebaseConfig);
        const database = firebase.database();
        const auth = firebase.auth();

        const tmdbApiKey = '2e211dfda888f7cc55ce433d743f9bc3';
        let allMoviesData = [];

        // ========== VIEW NAVIGATION ==========
        function showView(viewId) {
            document.querySelectorAll('.view').forEach(view => view.classList.remove('active'));
            document.getElementById(viewId).classList.add('active');
            document.querySelectorAll('.nav-item a').forEach(link => link.classList.remove('active'));
            
            const navMap = {
                'dashboard-view': 'nav-dashboard',
                'manage-movies-view': 'nav-manage-movies',
                'add-movie-view': 'nav-add-movie',
                'manage-series-view': 'nav-manage-series',
                'add-series-view': 'nav-add-series',
                'manage-shorts-view': 'nav-manage-shorts',
                'add-short-view': 'nav-add-short',
                'manage-categories-view': 'nav-manage-categories',
                'manage-livetv-view': 'nav-manage-livetv',
                'add-livetv-view': 'nav-add-livetv',
                'manage-ads-view': 'nav-manage-ads',
                'manage-plans-view': 'nav-manage-plans',
                'payment-settings-view': 'nav-payment-settings',
                'premium-requests-view': 'nav-premium-requests',
                'manual-premium-view': 'nav-manual-premium',
                'redeem-codes-view': 'nav-redeem-codes',
                'users-view': 'nav-users',
                'movie-requests-view': 'nav-movie-requests',
                'send-notification-view': 'nav-send-notification',
                'manage-avatars-view': 'nav-manage-avatars',
                'app-control-view': 'nav-app-control',
                'maintenance-view': 'nav-maintenance'
            };
            
            const activeNavId = navMap[viewId];
            if (activeNavId) document.getElementById(activeNavId).classList.add('active');
            
            const sidebar = document.getElementById('sidebar');
            if (window.innerWidth <= 992 && sidebar.classList.contains('open')) {
                sidebar.classList.remove('open');
            }
            
            // Load data for specific views
            if (viewId === 'manage-shorts-view') loadShorts();
            if (viewId === 'add-short-view' && !document.getElementById('short-edit-id').value) clearShortForm();
            if (viewId === 'add-movie-view' && !document.getElementById('movie-edit-id').value) clearMovieForm();
            if (viewId === 'add-series-view' && !document.getElementById('series-edit-id').value) clearSeriesForm();
            if (viewId === 'add-livetv-view' && !document.getElementById('livetv-edit-id').value) clearLiveTvForm();
            if (viewId === 'manage-ads-view' && !document.getElementById('ad-edit-id').value) clearAdForm();
        }

        // ========== INITIALIZATION ==========
        document.addEventListener('DOMContentLoaded', () => {
            const sidebar = document.getElementById('sidebar');
            const menuToggle = document.getElementById('menu-toggle');
            const mainContent = document.querySelector('.main-content');
            
            if (menuToggle) {
                menuToggle.addEventListener('click', (e) => {
                    e.stopPropagation();
                    sidebar.classList.toggle('open');
                });
            }
            if (mainContent) {
                mainContent.addEventListener('click', () => {
                    if (window.innerWidth <= 992 && sidebar.classList.contains('open')) {
                        sidebar.classList.remove('open');
                    }
                });
            }
            
            loadMovies(); loadSeries(); loadShorts(); loadLiveTvChannels(); loadCategories();
            loadUsers(); loadMovieRequests(); loadAvatars(); loadMaintenanceStatus();
            loadPlans(); loadPremiumRequests(); loadPaymentDetails(); loadRevenueAnalytics();
            loadAds(); loadAppControlSettings(); loadRedeemCodes();
            
            showView('dashboard-view');
            document.getElementById('notif-movie-search').addEventListener('input', searchMovieForNotif);
            document.getElementById('payment-qr-code').addEventListener('input', function() {
                const url = this.value;
                const preview = document.getElementById('qr-preview');
                const img = document.getElementById('qr-preview-img');
                if (url) { img.src = url; preview.style.display = 'block'; }
                else { preview.style.display = 'none'; }
            });
        });

        function showStatus(message, type) {
            const statusEl = document.getElementById('status-message');
            statusEl.textContent = message;
            statusEl.className = `status-message ${type}`;
            statusEl.style.display = 'block';
            setTimeout(() => statusEl.style.display = 'none', 3000);
        }

        // ========== SHORTS FUNCTIONS ==========
        function clearShortForm() {
            document.getElementById('short-edit-id').value = '';
            document.getElementById('short-form-title').textContent = 'Add New Short';
            document.getElementById('save-short-btn').textContent = 'Save Short';
            document.getElementById('short-title').value = '';
            document.getElementById('short-description').value = '';
            document.getElementById('short-video-url').value = '';
            document.getElementById('short-thumbnail').value = '';
            document.getElementById('short-is-new').checked = false;
            document.getElementById('short-is-premium').checked = false;
            document.querySelectorAll('#short-category-wrapper input[type="checkbox"]').forEach(cb => cb.checked = false);
        }

        function loadShorts() {
            const gridContainer = document.getElementById('shorts-grid-container');
            const totalStat = document.getElementById('total-shorts-stat');
            database.ref('shorts').orderByChild('timestamp').on('value', snapshot => {
                gridContainer.innerHTML = '';
                if (totalStat) totalStat.textContent = snapshot.numChildren();
                if (!snapshot.exists()) {
                    gridContainer.innerHTML = '<p style="color: var(--text-secondary);">No shorts found.</p>';
                    return;
                }
                snapshot.forEach(child => {
                    const short = child.val();
                    const id = child.key;
                    const card = document.createElement('div');
                    card.className = 'movie-card';
                    card.innerHTML = `
                        <img src="${short.thumbnail || 'https://via.placeholder.com/200x300?text=No+Thumb'}" alt="${short.title}" loading="lazy">
                        <div class="movie-card-overlay">
                            <div class="movie-card-info"><h3>${short.title}</h3><p>${short.description || ''}</p></div>
                            <div class="movie-card-actions">
                                <button class="btn-icon" onclick="editShort('${id}')"><i class="fa-solid fa-pencil"></i></button>
                                <button class="btn-icon" onclick="deleteData('shorts', '${id}')"><i class="fa-solid fa-trash"></i></button>
                            </div>
                        </div>`;
                    gridContainer.prepend(card);
                });
            });
        }

        function handleSaveShort() {
            const editId = document.getElementById('short-edit-id').value;
            const selectedCategories = Array.from(document.querySelectorAll('#short-category-wrapper input:checked')).map(cb => cb.value).join(', ');
            const shortData = {
                title: document.getElementById('short-title').value.trim(),
                description: document.getElementById('short-description').value.trim(),
                videoUrl: document.getElementById('short-video-url').value.trim(),
                thumbnail: document.getElementById('short-thumbnail').value.trim(),
                category: selectedCategories,
                isNew: document.getElementById('short-is-new').checked,
                isPremium: document.getElementById('short-is-premium').checked,
                timestamp: Date.now()
            };
            
            if (!shortData.title || !shortData.videoUrl) {
                showStatus('Title and Video URL are required.', 'error');
                return;
            }
            
            if (editId) {
                database.ref('shorts/' + editId).update(shortData)
                    .then(() => { showStatus('Short updated!', 'success'); clearShortForm(); showView('manage-shorts-view'); })
                    .catch(err => showStatus('Update failed: ' + err.message, 'error'));
            } else {
                database.ref('shorts').push(shortData)
                    .then(() => { showStatus('Short saved!', 'success'); clearShortForm(); showView('manage-shorts-view'); })
                    .catch(err => showStatus('Save failed: ' + err.message, 'error'));
            }
        }

        function editShort(id) {
            database.ref('shorts/' + id).once('value').then(snapshot => {
                const short = snapshot.val();
                if (!short) return;
                clearShortForm();
                document.getElementById('short-edit-id').value = id;
                document.getElementById('short-form-title').textContent = 'Edit Short';
                document.getElementById('save-short-btn').textContent = 'Update Short';
                document.getElementById('short-title').value = short.title || '';
                document.getElementById('short-description').value = short.description || '';
                document.getElementById('short-video-url').value = short.videoUrl || '';
                document.getElementById('short-thumbnail').value = short.thumbnail || '';
                document.getElementById('short-is-new').checked = short.isNew || false;
                document.getElementById('short-is-premium').checked = short.isPremium || false;
                
                const cats = short.category ? short.category.split(', ') : [];
                document.querySelectorAll('#short-category-wrapper input[type="checkbox"]').forEach(cb => {
                    cb.checked = cats.includes(cb.value);
                });
                showView('add-short-view');
            });
        }

        // ========== MOVIE FUNCTIONS ==========
        function clearMovieForm() {
            document.getElementById('movie-edit-id').value = '';
            document.getElementById('movie-form-title').textContent = 'Add New Movie';
            document.getElementById('save-movie-btn').textContent = 'Save Movie';
            document.getElementById('movie-tmdb-search').value = '';
            document.getElementById('movie-title').value = '';
            document.getElementById('movie-poster').value = '';
            document.getElementById('movie-backdrop').value = '';
            document.getElementById('movie-rating').value = '';
            document.getElementById('movie-year').value = '';
            document.getElementById('movie-storyline').value = '';
            document.getElementById('movie-link').value = '';
            document.getElementById('movie-quality-badge').value = 'none';
            document.getElementById('movie-is-new').checked = false;
            document.getElementById('movie-is-premium').checked = false;
            document.getElementById('movie-cast-container').innerHTML = '';
            document.querySelectorAll('#movie-category-wrapper input[type="checkbox"]').forEach(cb => cb.checked = false);
        }

        function loadMovies() {
            const gridContainer = document.getElementById('movie-grid-container');
            const totalStat = document.getElementById('total-movies-stat');
            database.ref('movies').orderByChild('timestamp').on('value', snapshot => {
                gridContainer.innerHTML = '';
                allMoviesData = [];
                totalStat.textContent = snapshot.numChildren();
                if (!snapshot.exists()) {
                    gridContainer.innerHTML = '<p style="color: var(--text-secondary);">No movies found.</p>';
                    return;
                }
                snapshot.forEach(child => {
                    const movie = child.val();
                    const id = child.key;
                    allMoviesData.push({ id, ...movie });
                    const card = document.createElement('div');
                    card.className = 'movie-card';
                    card.innerHTML = `
                        <img src="${movie.poster}" alt="${movie.title}" loading="lazy">
                        <div class="movie-card-overlay">
                            <div class="movie-card-info"><h3>${movie.title}</h3><p>${movie.year} • ${movie.rating} <i class="fa-solid fa-star fa-xs"></i></p></div>
                            <div class="movie-card-actions">
                                <button class="btn-icon" onclick="editMovie('${id}')"><i class="fa-solid fa-pencil"></i></button>
                                <button class="btn-icon" onclick="deleteData('movies', '${id}')"><i class="fa-solid fa-trash"></i></button>
                            </div>
                        </div>`;
                    gridContainer.prepend(card);
                });
            });
        }

        function handleSaveMovie() {
            const editId = document.getElementById('movie-edit-id').value;
            const selectedCategories = Array.from(document.querySelectorAll('#movie-category-wrapper input:checked')).map(cb => cb.value).join(', ');
            const movieData = {
                title: document.getElementById('movie-title').value,
                poster: document.getElementById('movie-poster').value,
                backdrop: document.getElementById('movie-backdrop').value,
                rating: document.getElementById('movie-rating').value,
                year: document.getElementById('movie-year').value,
                storyline: document.getElementById('movie-storyline').value,
                category: selectedCategories,
                qualityBadge: document.getElementById('movie-quality-badge').value,
                isNew: document.getElementById('movie-is-new').checked,
                isPremium: document.getElementById('movie-is-premium').checked,
                cast: Array.from(document.querySelectorAll('#movie-cast-container .cast-item')).map(item => ({
                    name: item.querySelector('p').textContent,
                    photo: item.querySelector('img').src
                })),
                link: document.getElementById('movie-link').value,
                type: 'movie',
                timestamp: Date.now()
            };
            
            if (editId) {
                database.ref('movies/' + editId).update(movieData)
                    .then(() => { showStatus('Movie updated!', 'success'); clearMovieForm(); showView('manage-movies-view'); })
                    .catch(err => showStatus('Update failed: ' + err.message, 'error'));
            } else {
                database.ref('movies').push(movieData)
                    .then(() => { showStatus('Movie saved!', 'success'); clearMovieForm(); showView('manage-movies-view'); })
                    .catch(err => showStatus('Save failed: ' + err.message, 'error'));
            }
        }

        function editMovie(id) {
            database.ref('movies/' + id).once('value').then(snapshot => {
                const movie = snapshot.val();
                if (!movie) return;
                clearMovieForm();
                document.getElementById('movie-edit-id').value = id;
                document.getElementById('movie-form-title').textContent = 'Edit Movie';
                document.getElementById('save-movie-btn').textContent = 'Update Movie';
                document.getElementById('movie-title').value = movie.title || '';
                document.getElementById('movie-poster').value = movie.poster || '';
                document.getElementById('movie-backdrop').value = movie.backdrop || '';
                document.getElementById('movie-rating').value = movie.rating || '';
                document.getElementById('movie-year').value = movie.year || '';
                document.getElementById('movie-storyline').value = movie.storyline || '';
                
                const cats = movie.category ? movie.category.split(', ') : [];
                document.querySelectorAll('#movie-category-wrapper input[type="checkbox"]').forEach(cb => {
                    cb.checked = cats.includes(cb.value);
                });
                
                document.getElementById('movie-quality-badge').value = movie.qualityBadge || 'none';
                document.getElementById('movie-is-new').checked = movie.isNew || false;
                document.getElementById('movie-is-premium').checked = movie.isPremium || false;
                document.getElementById('movie-link').value = movie.link || '';
                if (movie.cast) movie.cast.forEach(actor => addCastMember(actor, 'movie-cast-container'));
                showView('add-movie-view');
            });
        }

        // ========== SERIES FUNCTIONS ==========
        function clearSeriesForm() {
            document.getElementById('series-edit-id').value = '';
            document.getElementById('series-form-title').textContent = 'Add New Series';
            document.getElementById('save-series-btn').textContent = 'Save Series';
            document.getElementById('series-tmdb-search').value = '';
            document.getElementById('series-title').value = '';
            document.getElementById('series-poster').value = '';
            document.getElementById('series-backdrop').value = '';
            document.getElementById('series-rating').value = '';
            document.getElementById('series-year').value = '';
            document.getElementById('series-storyline').value = '';
            document.getElementById('series-quality-badge').value = 'none';
            document.getElementById('series-is-new').checked = false;
            document.getElementById('series-is-premium').checked = false;
            document.getElementById('series-seasons-container').innerHTML = '';
            document.getElementById('series-cast-container').innerHTML = '';
            document.querySelectorAll('#series-category-wrapper input[type="checkbox"]').forEach(cb => cb.checked = false);
        }

        function loadSeries() {
            const gridContainer = document.getElementById('series-grid-container');
            const totalStat = document.getElementById('total-series-stat');
            database.ref('webseries').orderByChild('timestamp').on('value', snapshot => {
                gridContainer.innerHTML = '';
                totalStat.textContent = snapshot.numChildren();
                if (!snapshot.exists()) {
                    gridContainer.innerHTML = '<p style="color: var(--text-secondary);">No series found.</p>';
                    return;
                }
                snapshot.forEach(child => {
                    const series = child.val();
                    const id = child.key;
                    const card = document.createElement('div');
                    card.className = 'movie-card';
                    card.innerHTML = `
                        <img src="${series.poster}" alt="${series.title}" loading="lazy">
                        <div class="movie-card-overlay">
                            <div class="movie-card-info"><h3>${series.title}</h3><p>${series.year} • ${series.rating} <i class="fa-solid fa-star fa-xs"></i></p></div>
                            <div class="movie-card-actions">
                                <button class="btn-icon" onclick="editSeries('${id}')"><i class="fa-solid fa-pencil"></i></button>
                                <button class="btn-icon" onclick="deleteData('webseries', '${id}')"><i class="fa-solid fa-trash"></i></button>
                            </div>
                        </div>`;
                    gridContainer.prepend(card);
                });
            });
        }

        function handleSaveSeries() {
            const editId = document.getElementById('series-edit-id').value;
            const episodes = [];
            document.querySelectorAll('.season-block').forEach(seasonBlock => {
                const seasonNumber = seasonBlock.querySelector('.season-number').value;
                seasonBlock.querySelectorAll('.episode-block').forEach(episodeBlock => {
                    episodes.push({
                        season: seasonNumber,
                        episode: episodeBlock.querySelector('.episode-number').value,
                        title: episodeBlock.querySelector('.episode-title').value,
                        thumbnail: episodeBlock.querySelector('.episode-thumbnail').value,
                        link: episodeBlock.querySelector('.episode-link').value,
                        isPremium: episodeBlock.querySelector('.episode-premium').checked
                    });
                });
            });
            
            const selectedCategories = Array.from(document.querySelectorAll('#series-category-wrapper input:checked')).map(cb => cb.value).join(', ');
            const seriesData = {
                title: document.getElementById('series-title').value,
                poster: document.getElementById('series-poster').value,
                backdrop: document.getElementById('series-backdrop').value,
                rating: document.getElementById('series-rating').value,
                year: document.getElementById('series-year').value,
                storyline: document.getElementById('series-storyline').value,
                category: selectedCategories,
                qualityBadge: document.getElementById('series-quality-badge').value,
                isNew: document.getElementById('series-is-new').checked,
                isPremium: document.getElementById('series-is-premium').checked,
                cast: Array.from(document.querySelectorAll('#series-cast-container .cast-item')).map(item => ({
                    name: item.querySelector('p').textContent,
                    photo: item.querySelector('img').src
                })),
                episodes: episodes,
                type: 'webseries',
                timestamp: Date.now()
            };
            
            if (editId) {
                database.ref('webseries/' + editId).update(seriesData)
                    .then(() => { showStatus('Series updated!', 'success'); clearSeriesForm(); showView('manage-series-view'); })
                    .catch(err => showStatus('Update failed: ' + err.message, 'error'));
            } else {
                database.ref('webseries').push(seriesData)
                    .then(() => { showStatus('Series saved!', 'success'); clearSeriesForm(); showView('manage-series-view'); })
                    .catch(err => showStatus('Save failed: ' + err.message, 'error'));
            }
        }

        function editSeries(id) {
            database.ref('webseries/' + id).once('value').then(snapshot => {
                const series = snapshot.val();
                if (!series) return;
                clearSeriesForm();
                document.getElementById('series-edit-id').value = id;
                document.getElementById('series-form-title').textContent = 'Edit Series';
                document.getElementById('save-series-btn').textContent = 'Update Series';
                document.getElementById('series-title').value = series.title || '';
                document.getElementById('series-poster').value = series.poster || '';
                document.getElementById('series-backdrop').value = series.backdrop || '';
                document.getElementById('series-rating').value = series.rating || '';
                document.getElementById('series-year').value = series.year || '';
                document.getElementById('series-storyline').value = series.storyline || '';
                
                const cats = series.category ? series.category.split(', ') : [];
                document.querySelectorAll('#series-category-wrapper input[type="checkbox"]').forEach(cb => {
                    cb.checked = cats.includes(cb.value);
                });
                
                document.getElementById('series-quality-badge').value = series.qualityBadge || 'none';
                document.getElementById('series-is-new').checked = series.isNew || false;
                document.getElementById('series-is-premium').checked = series.isPremium || false;
                
                if (series.cast) series.cast.forEach(actor => addCastMember(actor, 'series-cast-container'));
                
                const seasonsContainer = document.getElementById('series-seasons-container');
                seasonsContainer.innerHTML = '';
                let episodes = series.episodes;
                if (episodes && !Array.isArray(episodes)) episodes = Object.values(episodes);
                if (episodes) {
                    const episodesBySeason = episodes.reduce((acc, ep) => {
                        (acc[ep.season] = acc[ep.season] || []).push(ep);
                        return acc;
                    }, {});
                    for (const seasonNumber in episodesBySeason) {
                        const seasonBlock = addSeason(seasonNumber);
                        const epsContainer = seasonBlock.querySelector('.episodes-container');
                        episodesBySeason[seasonNumber].forEach(ep => addEpisode(epsContainer, ep));
                    }
                }
                showView('add-series-view');
            });
        }

        function addSeason(seasonNumber = '') {
            const container = document.getElementById('series-seasons-container');
            const seasonBlock = document.createElement('div');
            seasonBlock.className = 'season-block';
            seasonBlock.innerHTML = `
                <div class="season-header">
                    <label>Season Number:</label>
                    <input type="number" class="season-number" value="${seasonNumber}" placeholder="e.g., 1">
                    <button type="button" class="btn-sm" onclick="addEpisode(this.closest('.season-block').querySelector('.episodes-container'))">+ Add Episode</button>
                    <button type="button" class="remove-btn" onclick="removeElement(this.parentElement.parentElement)" style="margin-left: auto; position: static; transform: none;">&times; Remove Season</button>
                </div>
                <div class="episodes-container"></div>`;
            container.appendChild(seasonBlock);
            return seasonBlock;
        }

        function addEpisode(container, episodeData = {}) {
            const episodeBlock = document.createElement('div');
            episodeBlock.className = 'episode-block';
            episodeBlock.innerHTML = `
                <button type="button" class="remove-btn" onclick="removeElement(this)">&times;</button>
                <div class="form-group"><label>Ep. Number</label><input type="number" class="episode-number" placeholder="1" value="${episodeData.episode || ''}"></div>
                <div class="form-group"><label>Ep. Title</label><input type="text" class="episode-title" placeholder="Episode Title" value="${episodeData.title || ''}"></div>
                <div class="form-group full-width"><label>Thumbnail URL</label><input type="text" class="episode-thumbnail" placeholder="https://.../thumb.jpg" value="${episodeData.thumbnail || ''}"></div>
                <div class="form-group full-width"><label>Stream Link</label><input type="text" class="episode-link" placeholder="https://.../stream.mp4" value="${episodeData.link || ''}"></div>
                <div class="form-group full-width">
                    <label style="color: #ffb700; font-size: 13px; font-weight:600; cursor:pointer;">
                        <input type="checkbox" class="episode-premium" style="width:auto; margin-right:5px;" ${episodeData.isPremium ? 'checked' : ''}> <i class="fa-solid fa-lock"></i> Premium Episode
                    </label>
                </div>`;
            container.appendChild(episodeBlock);
        }

        function removeElement(button) {
            button.closest('.season-block, .episode-block, .cast-item')?.remove();
        }

        function addCastMember(castData, containerId) {
            const container = document.getElementById(containerId);
            const castItem = document.createElement('div');
            castItem.className = 'cast-item';
            castItem.innerHTML = `
                <button type="button" class="remove-btn" onclick="removeElement(this)">&times;</button>
                <img src="${castData.photo || 'https://via.placeholder.com/70x70?text=N/A'}" alt="${castData.name}">
                <p>${castData.name}</p>`;
            container.appendChild(castItem);
        }

        function deleteData(type, id) {
            if (confirm(`Permanently delete this item?`)) {
                database.ref(`${type}/${id}`).remove()
                    .then(() => showStatus('Item deleted!', 'success'))
                    .catch(err => showStatus('Delete failed: ' + err.message, 'error'));
            }
        }

        // ========== CATEGORY FUNCTIONS ==========
        function loadCategories() {
            const listContainer = document.getElementById('category-list-container');
            const movieWrapper = document.getElementById('movie-category-wrapper');
            const seriesWrapper = document.getElementById('series-category-wrapper');
            const shortsWrapper = document.getElementById('short-category-wrapper');
            
            database.ref('categories').orderByChild('name').on('value', snapshot => {
                if (listContainer) listContainer.innerHTML = '';
                if (movieWrapper) movieWrapper.innerHTML = '';
                if (seriesWrapper) seriesWrapper.innerHTML = '';
                if (shortsWrapper) shortsWrapper.innerHTML = '';
                
                if (!snapshot.exists()) {
                    const msg = '<p style="color: var(--text-secondary);">No categories available.</p>';
                    if (listContainer) listContainer.innerHTML = msg;
                    if (movieWrapper) movieWrapper.innerHTML = msg;
                    if (seriesWrapper) seriesWrapper.innerHTML = msg;
                    if (shortsWrapper) shortsWrapper.innerHTML = msg;
                    return;
                }
                
                snapshot.forEach(child => {
                    const category = child.val();
                    const id = child.key;
                    
                    if (listContainer) {
                        const item = document.createElement('div');
                        item.className = 'category-item';
                        item.id = `cat-item-${id}`;
                        item.innerHTML = `
                            <div class="view-mode">
                                <span class="category-name-text">${category.name}</span>
                                <div class="actions">
                                    <button class="btn-icon" onclick="toggleCategoryEdit('${id}', true)"><i class="fa-solid fa-pencil"></i></button>
                                    <button class="btn-icon" onclick="deleteCategory('${id}')"><i class="fa-solid fa-trash"></i></button>
                                </div>
                            </div>
                            <div class="edit-mode" style="display: none;">
                                <input type="text" class="category-edit-input" value="${category.name}">
                                <div class="actions">
                                    <button class="btn-icon" onclick="updateCategoryName('${id}')"><i class="fa-solid fa-check"></i></button>
                                    <button class="btn-icon" onclick="toggleCategoryEdit('${id}', false)"><i class="fa-solid fa-times"></i></button>
                                </div>
                            </div>`;
                        listContainer.appendChild(item);
                    }
                    
                    const createCheckbox = (name) => {
                        const label = document.createElement('label');
                        label.className = 'category-checkbox-item';
                        label.innerHTML = `<input type="checkbox" value="${name}"> ${name}`;
                        return label;
                    };
                    
                    if (movieWrapper) movieWrapper.appendChild(createCheckbox(category.name));
                    if (seriesWrapper) seriesWrapper.appendChild(createCheckbox(category.name));
                    if (shortsWrapper) shortsWrapper.appendChild(createCheckbox(category.name));
                });
            });
        }

        function handleSaveCategory() {
            const name = document.getElementById('category-name').value.trim();
            if (!name) { showStatus('Category name cannot be empty.', 'error'); return; }
            database.ref('categories').push({ name, timestamp: Date.now() })
                .then(() => { showStatus('Category saved!', 'success'); document.getElementById('category-name').value = ''; })
                .catch(err => showStatus('Save failed: ' + err.message, 'error'));
        }

        function deleteCategory(id) {
            if (confirm('Delete this category?')) {
                database.ref(`categories/${id}`).remove()
                    .then(() => showStatus('Category deleted!', 'success'))
                    .catch(err => showStatus('Delete failed: ' + err.message, 'error'));
            }
        }

        function toggleCategoryEdit(id, isEditing) {
            const item = document.getElementById(`cat-item-${id}`);
            const viewMode = item.querySelector('.view-mode');
            const editMode = item.querySelector('.edit-mode');
            if (isEditing) {
                viewMode.style.display = 'none';
                editMode.style.display = 'flex';
                editMode.querySelector('input').focus();
            } else {
                viewMode.style.display = 'flex';
                editMode.style.display = 'none';
                editMode.querySelector('input').value = viewMode.querySelector('.category-name-text').textContent;
            }
        }

        function updateCategoryName(id) {
            const item = document.getElementById(`cat-item-${id}`);
            const newName = item.querySelector('.edit-mode input').value.trim();
            if (!newName) { showStatus('Category name cannot be empty.', 'error'); return; }
            
            database.ref(`categories/${id}`).update({ name: newName })
                .then(() => { showStatus('Category updated!', 'success'); toggleCategoryEdit(id, false); })
                .catch(err => showStatus('Update failed: ' + err.message, 'error'));
        }

        // ========== LIVE TV FUNCTIONS ==========
        function clearLiveTvForm() {
            document.getElementById('livetv-edit-id').value = '';
            document.getElementById('livetv-form-title').textContent = 'Add New Live TV Channel';
            document.getElementById('save-livetv-btn').textContent = 'Save Channel';
            document.getElementById('livetv-name').value = '';
            document.getElementById('livetv-logo').value = '';
            document.getElementById('livetv-stream').value = '';
            document.getElementById('livetv-category').value = 'Entertainment';
        }

        function loadLiveTvChannels() {
            const gridContainer = document.getElementById('livetv-grid-container');
            const totalStat = document.getElementById('total-livetv-stat');
            database.ref('livetv').orderByChild('timestamp').on('value', snapshot => {
                gridContainer.innerHTML = '';
                totalStat.textContent = snapshot.numChildren();
                if (!snapshot.exists()) {
                    gridContainer.innerHTML = '<p style="color: var(--text-secondary);">No Live TV channels found.</p>';
                    return;
                }
                snapshot.forEach(child => {
                    const channel = child.val();
                    const id = child.key;
                    const card = document.createElement('div');
                    card.className = 'livetv-card';
                    card.innerHTML = `
                        <div class="logo-container"><img src="${channel.logoUrl}" alt="${channel.name}"></div>
                        <h3>${channel.name}</h3>
                        <div class="movie-card-actions" style="background:none;">
                            <button class="btn-icon" onclick="editLiveTvChannel('${id}')"><i class="fa-solid fa-pencil"></i></button>
                            <button class="btn-icon" onclick="deleteData('livetv', '${id}')"><i class="fa-solid fa-trash"></i></button>
                        </div>`;
                    gridContainer.prepend(card);
                });
            });
        }

        function handleSaveLiveTv() {
            const editId = document.getElementById('livetv-edit-id').value;
            const channelData = {
                name: document.getElementById('livetv-name').value.trim(),
                logoUrl: document.getElementById('livetv-logo').value.trim(),
                streamUrl: document.getElementById('livetv-stream').value.trim(),
                category: document.getElementById('livetv-category').value,
                timestamp: Date.now()
            };
            if (!channelData.name || !channelData.logoUrl || !channelData.streamUrl) {
                showStatus('All fields are required.', 'error'); return;
            }
            if (editId) {
                database.ref('livetv/' + editId).update(channelData)
                    .then(() => { showStatus('Channel updated!', 'success'); clearLiveTvForm(); showView('manage-livetv-view'); })
                    .catch(err => showStatus('Update failed: ' + err.message, 'error'));
            } else {
                database.ref('livetv').push(channelData)
                    .then(() => { showStatus('Channel saved!', 'success'); clearLiveTvForm(); showView('manage-livetv-view'); })
                    .catch(err => showStatus('Save failed: ' + err.message, 'error'));
            }
        }

        function editLiveTvChannel(id) {
            database.ref('livetv/' + id).once('value').then(snapshot => {
                const channel = snapshot.val();
                if (!channel) return;
                document.getElementById('livetv-edit-id').value = id;
                document.getElementById('livetv-form-title').textContent = 'Edit Live TV Channel';
                document.getElementById('save-livetv-btn').textContent = 'Update Channel';
                document.getElementById('livetv-name').value = channel.name || '';
                document.getElementById('livetv-logo').value = channel.logoUrl || '';
                document.getElementById('livetv-stream').value = channel.streamUrl || '';
                document.getElementById('livetv-category').value = channel.category || 'Entertainment';
                showView('add-livetv-view');
            });
        }

        // ========== TMDB SEARCH ==========
        async function searchTmdb(type) {
            const query = document.getElementById(`${type === 'movie' ? 'movie' : 'series'}-tmdb-search`).value.trim();
            if (!query) { showStatus('Please enter a search query or ID', 'error'); return; }
            if (/^\d+$/.test(query)) { fetchDetailsById(type, query); return; }
            try {
                const response = await fetch(`https://api.themoviedb.org/3/search/${type}?api_key=${tmdbApiKey}&query=${encodeURIComponent(query)}`);
                const data = await response.json();
                if (data.results?.length) displaySearchResults(type, data.results);
                else showStatus('No results found.', 'error');
            } catch { showStatus('Search failed.', 'error'); }
        }

        function displaySearchResults(type, results) {
            const container = document.getElementById('search-results-container');
            container.innerHTML = '';
            results.slice(0, 10).forEach(item => {
                const title = type === 'movie' ? item.title : item.name;
                const year = (type === 'movie' ? item.release_date : item.first_air_date)?.split('-')[0] || 'N/A';
                const poster = item.poster_path ? `https://image.tmdb.org/t/p/w92${item.poster_path}` : 'https://via.placeholder.com/50x75?text=No+Img';
                const div = document.createElement('div');
                div.className = 'search-result-item';
                div.onclick = () => selectTmdbResult(type, item.id);
                div.innerHTML = `<img src="${poster}" alt="${title}"><div class="search-result-info"><h4>${title}</h4><p>${year}</p></div>`;
                container.appendChild(div);
            });
            document.getElementById('search-modal').style.display = 'flex';
        }

        function closeSearchModal() { document.getElementById('search-modal').style.display = 'none'; }
        function selectTmdbResult(type, id) { closeSearchModal(); fetchDetailsById(type, id); }

        async function fetchDetailsById(type, id) {
            try {
                const response = await fetch(`https://api.themoviedb.org/3/${type}/${id}?api_key=${tmdbApiKey}&append_to_response=credits`);
                const data = await response.json();
                if (type === 'movie') populateMovieForm(data);
                else populateSeriesForm(data);
                showStatus('Data fetched successfully!', 'success');
            } catch { showStatus('Failed to fetch details.', 'error'); }
        }

        function populateMovieForm(data) {
            document.getElementById('movie-title').value = data.title;
            document.getElementById('movie-poster').value = data.poster_path ? `https://image.tmdb.org/t/p/w500${data.poster_path}` : '';
            document.getElementById('movie-backdrop').value = data.backdrop_path ? `https://image.tmdb.org/t/p/w1280${data.backdrop_path}` : '';
            document.getElementById('movie-year').value = data.release_date?.split('-')[0] || '';
            document.getElementById('movie-rating').value = data.vote_average?.toFixed(1) || '';
            document.getElementById('movie-storyline').value = data.overview;
            
            const tmdbGenres = data.genres.map(g => g.name);
            document.querySelectorAll('#movie-category-wrapper input[type="checkbox"]').forEach(cb => {
                cb.checked = tmdbGenres.includes(cb.value);
            });
            
            const castContainer = document.getElementById('movie-cast-container');
            castContainer.innerHTML = '';
            data.credits?.cast?.slice(0, 12).forEach(actor => {
                addCastMember({
                    name: actor.name,
                    photo: actor.profile_path ? `https://image.tmdb.org/t/p/w185${actor.profile_path}` : ''
                }, 'movie-cast-container');
            });
        }

        function populateSeriesForm(data) {
            document.getElementById('series-title').value = data.name;
            document.getElementById('series-poster').value = data.poster_path ? `https://image.tmdb.org/t/p/w500${data.poster_path}` : '';
            document.getElementById('series-backdrop').value = data.backdrop_path ? `https://image.tmdb.org/t/p/w1280${data.backdrop_path}` : '';
            document.getElementById('series-year').value = data.first_air_date?.split('-')[0] || '';
            document.getElementById('series-rating').value = data.vote_average?.toFixed(1) || '';
            document.getElementById('series-storyline').value = data.overview;
            
            const tmdbGenres = data.genres.map(g => g.name);
            document.querySelectorAll('#series-category-wrapper input[type="checkbox"]').forEach(cb => {
                cb.checked = tmdbGenres.includes(cb.value);
            });
            
            const castContainer = document.getElementById('series-cast-container');
            castContainer.innerHTML = '';
            data.credits?.cast?.slice(0, 12).forEach(actor => {
                addCastMember({
                    name: actor.name,
                    photo: actor.profile_path ? `https://image.tmdb.org/t/p/w185${actor.profile_path}` : ''
                }, 'series-cast-container');
            });
        }

        // ========== USERS & BAN ==========
        function loadUsers() {
            const tbody = document.getElementById('user-list-body');
            const totalStat = document.getElementById('total-users-stat');
            database.ref('users').on('value', snapshot => {
                tbody.innerHTML = '';
                totalStat.textContent = snapshot.numChildren();
                if (!snapshot.exists()) {
                    tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;">No users found.</td></tr>';
                    return;
                }
                snapshot.forEach(child => {
                    const user = child.val();
                    const uid = child.key;
                    const name = user.displayName || 'N/A';
                    const isBanned = user.isBanned || false;
                    const tr = document.createElement('tr');
                    if (isBanned) tr.classList.add('banned-row');
                    tr.innerHTML = `
                        <td><div style="display:flex;align-items:center;gap:10px;"><div class="user-avatar">${name.charAt(0).toUpperCase()}</div><span>${name}</span></div></td>
                        <td>${user.email}</td>
                        <td style="font-size:12px;color:var(--text-secondary);">${uid}</td>
                        <td>${isBanned ? '<span style="color:#c62828;">Banned</span>' : '<span style="color:#2e7d32;">Active</span>'}</td>
                        <td style="display:flex;gap:10px;">
                            <button class="btn-sm ${isBanned ? 'unban-btn' : 'ban-btn'}" onclick="toggleUserBan('${uid}', ${isBanned})">${isBanned ? '<i class="fa-solid fa-unlock"></i> Unban' : '<i class="fa-solid fa-ban"></i> Ban'}</button>
                            <button class="btn-icon" onclick="deleteUser('${uid}')"><i class="fa-solid fa-trash"></i></button>
                        </td>`;
                    tbody.appendChild(tr);
                });
            });
        }

        function toggleUserBan(uid, current) {
            if (confirm(`${current ? 'Unban' : 'Ban'} this user?`)) {
                database.ref(`users/${uid}/isBanned`).set(!current)
                    .then(() => showStatus(`User ${current ? 'unbanned' : 'banned'}!`, 'success'))
                    .catch(err => showStatus('Failed: ' + err.message, 'error'));
            }
        }

        function deleteUser(uid) {
            if (confirm('Remove user from database? (Does not delete Auth)')) {
                database.ref(`users/${uid}`).remove()
                    .then(() => showStatus('User removed.', 'success'))
                    .catch(err => showStatus('Failed: ' + err.message, 'error'));
            }
        }

        // ========== NOTIFICATIONS & REQUESTS ==========
        function toggleEmailTarget(show) {
            document.getElementById('email-target-container').style.display = show ? 'block' : 'none';
        }

        function searchMovieForNotif() {
            const query = document.getElementById('notif-movie-search').value.toLowerCase();
            const container = document.getElementById('notif-movie-search-results');
            container.innerHTML = '';
            if (query.length < 2) return;
            const results = allMoviesData.filter(m => m.title.toLowerCase().includes(query)).slice(0, 5);
            results.forEach(movie => {
                const div = document.createElement('div');
                div.className = 'search-result-item';
                div.onclick = () => selectMovieForNotif(movie);
                div.innerHTML = `<img src="${movie.poster}" alt="${movie.title}"><div class="search-result-info"><h4>${movie.title}</h4><p>${movie.year}</p></div>`;
                container.appendChild(div);
            });
        }

        function selectMovieForNotif(movie) {
            document.getElementById('notif-movie-id').value = movie.id;
            document.getElementById('notif-movie-poster').value = movie.poster;
            const preview = document.getElementById('notif-movie-preview');
            preview.innerHTML = `<img src="${movie.poster}"><div><h4>${movie.title}</h4><p style="font-size:12px;">Movie Attached</p></div>`;
            preview.style.display = 'flex';
            document.getElementById('notif-movie-search-results').innerHTML = '';
            document.getElementById('notif-movie-search').value = movie.title;
        }

        function handleSendNotification() {
            const notif = {
                title: document.getElementById('notif-title').value.trim(),
                message: document.getElementById('notif-message').value.trim(),
                icon: document.getElementById('notif-icon').value,
                movieId: document.getElementById('notif-movie-id').value,
                moviePoster: document.getElementById('notif-movie-poster').value,
                target: document.querySelector('input[name="target"]:checked').value,
                timestamp: Date.now()
            };
            if (!notif.title || !notif.message) { showStatus('Title and Message required.', 'error'); return; }
            if (notif.target === 'specific') {
                const emails = document.getElementById('notif-emails').value.split(',').map(e => e.trim()).filter(Boolean);
                if (!emails.length) { showStatus('Enter at least one email.', 'error'); return; }
                notif.targetEmails = emails;
            }
            database.ref('notifications').push(notif)
                .then(() => {
                    showStatus('Notification sent!', 'success');
                    document.getElementById('notif-title').value = '';
                    document.getElementById('notif-message').value = '';
                    document.getElementById('notif-movie-search').value = '';
                    document.getElementById('notif-movie-id').value = '';
                    document.getElementById('notif-emails').value = '';
                    document.getElementById('notif-movie-preview').style.display = 'none';
                    document.getElementById('notif-movie-search-results').innerHTML = '';
                })
                .catch(err => showStatus('Failed: ' + err.message, 'error'));
        }

        function loadMovieRequests() {
            const tbody = document.getElementById('request-list-body');
            const badge = document.getElementById('requests-badge');
            database.ref('movie_requests').orderByChild('timestamp').on('value', snapshot => {
                tbody.innerHTML = '';
                const count = snapshot.numChildren();
                badge.style.display = count ? 'flex' : 'none';
                if (count) badge.textContent = count;
                if (!count) { tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;">No pending requests.</td></tr>'; return; }
                snapshot.forEach(child => {
                    const req = child.val();
                    const id = child.key;
                    const date = new Date(req.timestamp).toLocaleDateString();
                    const tr = document.createElement('tr');
                    const safeName = req.movieName.replace(/'/g, "\\'");
                    tr.innerHTML = `
                        <td>${req.movieName}</td><td>${req.movieYear}</td><td>${req.requestedBy}</td><td>${date}</td>
                        <td><button class="btn-sm" onclick="completeRequest('${id}', '${req.requestedBy}', '${safeName}')"><i class="fa-solid fa-check"></i> Complete</button></td>`;
                    tbody.prepend(tr);
                });
            });
        }

        function completeRequest(id, email, movieName) {
            if (!confirm(`Mark "${movieName}" as complete and notify user?`)) return;
            database.ref('notifications').push({
                title: "Your Request is Here!",
                message: `The movie "${movieName}" has been added. Enjoy!`,
                icon: 'fa-check-circle',
                target: 'specific',
                targetEmails: [email],
                timestamp: Date.now()
            }).then(() => database.ref('movie_requests/' + id).remove())
              .then(() => showStatus('Request completed!', 'success'))
              .catch(err => showStatus('Error: ' + err.message, 'error'));
        }

        // ========== AVATARS ==========
        function loadAvatars() {
            const maleGrid = document.getElementById('male-avatars-grid');
            const femaleGrid = document.getElementById('female-avatars-grid');
            database.ref('app_settings/avatars').on('value', snapshot => {
                maleGrid.innerHTML = ''; femaleGrid.innerHTML = '';
                const avatars = snapshot.val() || {};
                const male = avatars.male || {}, female = avatars.female || {};
                
                if (!Object.keys(male).length) maleGrid.innerHTML = '<p style="color:var(--text-secondary);grid-column:1/-1;">No male avatars.</p>';
                else for (let key in male) maleGrid.appendChild(createAvatarCard('male', key, male[key]));
                
                if (!Object.keys(female).length) femaleGrid.innerHTML = '<p style="color:var(--text-secondary);grid-column:1/-1;">No female avatars.</p>';
                else for (let key in female) femaleGrid.appendChild(createAvatarCard('female', key, female[key]));
            });
        }

        function createAvatarCard(gender, key, url) {
            const card = document.createElement('div');
            card.className = 'avatar-card';
            card.innerHTML = `<img src="${url}" alt="Avatar"><button class="btn-icon delete-btn" onclick="deleteAvatar('${gender}', '${key}')"><i class="fa-solid fa-trash"></i></button>`;
            return card;
        }

        function addAvatar(gender) {
            const input = document.getElementById(`${gender}-avatar-url`);
            const url = input.value.trim();
            if (!url || !url.startsWith('http')) { showStatus('Enter a valid URL.', 'error'); return; }
            database.ref(`app_settings/avatars/${gender}`).push(url)
                .then(() => { showStatus('Avatar added!', 'success'); input.value = ''; })
                .catch(err => showStatus('Error: ' + err.message, 'error'));
        }

        function deleteAvatar(gender, key) {
            if (confirm('Delete this avatar?')) {
                database.ref(`app_settings/avatars/${gender}/${key}`).remove()
                    .then(() => showStatus('Avatar deleted.', 'success'))
                    .catch(err => showStatus('Error: ' + err.message, 'error'));
            }
        }

        // ========== MAINTENANCE & APP CONTROL ==========
        function loadMaintenanceStatus() {
            const toggle = document.getElementById('maintenance-toggle');
            const msg = document.getElementById('maintenance-message');
            const statusText = document.getElementById('maintenance-status-text');
            database.ref('maintenance').on('value', snapshot => {
                const data = snapshot.val();
                if (data?.enabled) {
                    toggle.checked = true;
                    msg.value = data.message || '';
                    statusText.textContent = 'App is IN MAINTENANCE';
                    statusText.style.color = 'var(--primary-color)';
                } else {
                    toggle.checked = false;
                    msg.value = data?.message || '';
                    statusText.textContent = 'App is LIVE';
                    statusText.style.color = 'var(--text-secondary)';
                }
            });
        }

        function handleSaveMaintenance() {
            const data = {
                enabled: document.getElementById('maintenance-toggle').checked,
                message: document.getElementById('maintenance-message').value.trim()
            };
            database.ref('maintenance').set(data)
                .then(() => showStatus('Maintenance settings updated!', 'success'))
                .catch(err => showStatus('Failed: ' + err.message, 'error'));
        }

        function loadAppControlSettings() {
            database.ref('app_settings/version').on('value', snapshot => {
                const data = snapshot.val();
                if (data) {
                    document.getElementById('app-ver-code').value = data.versionCode || '';
                    document.getElementById('app-ver-name').value = data.versionName || '';
                    document.getElementById('app-force-update').checked = data.forceUpdate || false;
                    document.getElementById('app-apk-url').value = data.apkUrl || '';
                    document.getElementById('app-changelog').value = data.changelog || '';
                }
            });
        }

        function saveAppControlSettings() {
            const data = {
                versionCode: parseInt(document.getElementById('app-ver-code').value),
                versionName: document.getElementById('app-ver-name').value.trim(),
                forceUpdate: document.getElementById('app-force-update').checked,
                apkUrl: document.getElementById('app-apk-url').value.trim(),
                changelog: document.getElementById('app-changelog').value.trim()
            };
            if (!data.versionCode || !data.versionName) { showStatus('Version Code and Name required.', 'error'); return; }
            database.ref('app_settings/version').set(data)
                .then(() => showStatus('App settings updated!', 'success'))
                .catch(err => showStatus('Error: ' + err.message, 'error'));
        }

        // ========== PREMIUM FEATURES ==========
        function savePlan() {
            const plan = {
                name: document.getElementById('plan-name').value.trim(),
                price: document.getElementById('plan-price').value.trim(),
                days: parseInt(document.getElementById('plan-days').value),
                devices: parseInt(document.getElementById('plan-devices').value),
                description: document.getElementById('plan-desc').value.trim(),
                timestamp: Date.now()
            };
            if (!plan.name || !plan.price || !plan.days || !plan.devices || !plan.description) {
                showStatus('All fields required.', 'error'); return;
            }
            database.ref('plans').push(plan)
                .then(() => {
                    showStatus('Plan added!', 'success');
                    document.getElementById('plan-name').value = '';
                    document.getElementById('plan-price').value = '';
                    document.getElementById('plan-days').value = '';
                    document.getElementById('plan-devices').value = '';
                    document.getElementById('plan-desc').value = '';
                })
                .catch(err => showStatus('Error: ' + err.message, 'error'));
        }

        function loadPlans() {
            const container = document.getElementById('plans-list-container');
            database.ref('plans').on('value', snapshot => {
                container.innerHTML = '';
                if (!snapshot.exists()) {
                    container.innerHTML = '<p style="color:var(--text-secondary)">No plans active.</p>';
                    return;
                }
                snapshot.forEach(child => {
                    const plan = child.val();
                    const key = child.key;
                    const card = document.createElement('div');
                    card.className = 'plan-card';
                    card.innerHTML = `
                        <h3>${plan.name}</h3><div class="price">${plan.price}</div>
                        <div class="details">
                            <span><i class="fa-solid fa-clock"></i> ${plan.days} Days</span>
                            <span><i class="fa-solid fa-mobile-screen"></i> ${plan.devices} Devices</span>
                            <span><i class="fa-solid fa-info-circle"></i> ${plan.description}</span>
                        </div>
                        <button class="btn-icon" style="position:absolute;top:15px;right:15px;" onclick="deleteData('plans', '${key}')"><i class="fa-solid fa-trash"></i></button>`;
                    container.appendChild(card);
                });
            });
        }

        function loadPremiumRequests() {
            const tbody = document.getElementById('premium-requests-body');
            const badge = document.getElementById('premium-badge');
            database.ref('premium_requests').on('value', snapshot => {
                tbody.innerHTML = '';
                let pending = 0;
                if (!snapshot.exists()) {
                    tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;">No requests.</td></tr>';
                    badge.style.display = 'none';
                    return;
                }
                snapshot.forEach(child => {
                    const req = child.val();
                    const key = child.key;
                    if (req.status === 'pending') {
                        pending++;
                        const date = new Date(req.timestamp).toLocaleDateString();
                        const tr = document.createElement('tr');
                        tr.innerHTML = `
                            <td>${req.userEmail || 'Unknown'}</td>
                            <td>${req.planName} (${req.planDays} Days)</td>
                            <td style="color:var(--primary-color);font-weight:bold;">${req.utr || 'N/A'}</td>
                            <td>${date}</td>
                            <td style="display:flex;gap:10px;">
                                <button class="btn-sm success" onclick="approvePremium('${key}', '${req.userId}', ${req.planDays}, '${req.planName}', ${req.deviceLimit || 1}, '${req.planPrice || 0}')"><i class="fa-solid fa-check"></i></button>
                                <button class="btn-sm error" onclick="rejectPremium('${key}')"><i class="fa-solid fa-times"></i></button>
                            </td>`;
                        tbody.prepend(tr);
                    }
                });
                if (pending) {
                    badge.textContent = pending;
                    badge.style.display = 'flex';
                } else {
                    badge.style.display = 'none';
                    tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;">No pending requests.</td></tr>';
                }
            });
        }

        function approvePremium(reqKey, uid, days, planName, deviceLimit, price) {
            if (!confirm('Approve this payment?')) return;
            const expiry = Date.now() + (days * 86400000);
            const sub = { isPremium: true, planName, expiryDate: expiry, startDate: Date.now(), deviceLimit };
            database.ref('users/' + uid + '/subscription').set(sub)
                .then(() => database.ref('premium_requests/' + reqKey).update({ status: 'approved', approvedAt: Date.now(), revenueAmount: price }))
                .then(() => database.ref('notifications').push({
                    title: "Premium Activated!",
                    message: `Your ${planName} plan is active until ${new Date(expiry).toLocaleDateString()}.`,
                    icon: "fa-crown", target: "specific", targetEmails: [uid], timestamp: Date.now()
                }))
                .then(() => showStatus('Premium granted!', 'success'))
                .catch(err => showStatus('Error: ' + err.message, 'error'));
        }

        function rejectPremium(reqKey) {
            if (!confirm('Reject this request?')) return;
            database.ref('premium_requests/' + reqKey).update({ status: 'rejected' })
                .then(() => showStatus('Request rejected.', 'error'))
                .catch(err => showStatus('Error: ' + err.message, 'error'));
        }

        function handleManualPremium() {
            const uid = document.getElementById('manual-uid').value.trim();
            const days = parseInt(document.getElementById('manual-days').value);
            if (!uid || !days) { showStatus('UID and Days required.', 'error'); return; }
            const expiry = Date.now() + (days * 86400000);
            database.ref('users/' + uid + '/subscription').set({
                isPremium: true, planName: 'Manual Grant', expiryDate: expiry, startDate: Date.now(), deviceLimit: 5
            }).then(() => {
                showStatus('Premium assigned!', 'success');
                document.getElementById('manual-uid').value = '';
                document.getElementById('manual-days').value = '';
            }).catch(err => showStatus('Failed: ' + err.message, 'error'));
        }

        function loadRevenueAnalytics() {
            database.ref('users').on('value', snapshot => {
                let vip = 0;
                const now = Date.now();
                snapshot.forEach(child => {
                    const sub = child.val().subscription;
                    if (sub?.isPremium && sub.expiryDate > now) vip++;
                });
                document.getElementById('total-vip-stat').textContent = vip;
            });
            database.ref('premium_requests').orderByChild('status').equalTo('approved').on('value', snapshot => {
                let revenue = 0, currency = '$';
                snapshot.forEach(child => {
                    const req = child.val();
                    const priceStr = req.planPrice || req.revenueAmount || "0";
                    const amount = parseFloat(priceStr.toString().replace(/[^0-9.]/g, ''));
                    if (!isNaN(amount)) revenue += amount;
                    if (priceStr.includes('INR') || priceStr.includes('₹')) currency = '₹';
                });
                document.getElementById('total-revenue-stat').textContent = currency + revenue.toFixed(2);
            });
        }

        function savePaymentDetails() {
            const data = {
                upiId: document.getElementById('payment-upi-id').value.trim(),
                qrCodeUrl: document.getElementById('payment-qr-code').value.trim()
            };
            database.ref('app_settings/payment').set(data)
                .then(() => showStatus('Payment details saved!', 'success'))
                .catch(err => showStatus('Error: ' + err.message, 'error'));
        }

        function loadPaymentDetails() {
            database.ref('app_settings/payment').on('value', snapshot => {
                const data = snapshot.val();
                if (data) {
                    document.getElementById('payment-upi-id').value = data.upiId || '';
                    document.getElementById('payment-qr-code').value = data.qrCodeUrl || '';
                    if (data.qrCodeUrl) {
                        document.getElementById('qr-preview-img').src = data.qrCodeUrl;
                        document.getElementById('qr-preview').style.display = 'block';
                    }
                }
            });
        }

        // ========== ADS MANAGEMENT ==========
        function clearAdForm() {
            document.getElementById('ad-edit-id').value = '';
            document.getElementById('save-ad-btn').textContent = 'Save Advertisement';
            document.getElementById('ad-title').value = '';
            document.getElementById('ad-media-url').value = '';
            document.getElementById('ad-target-url').value = '';
            document.getElementById('ad-duration').value = '5';
            document.getElementById('ad-is-active').checked = true;
        }

        function handleSaveAd() {
            const editId = document.getElementById('ad-edit-id').value;
            const ad = {
                title: document.getElementById('ad-title').value.trim(),
                type: document.getElementById('ad-type').value,
                mediaUrl: document.getElementById('ad-media-url').value.trim(),
                targetUrl: document.getElementById('ad-target-url').value.trim(),
                duration: parseInt(document.getElementById('ad-duration').value) || 5,
                isActive: document.getElementById('ad-is-active').checked,
                timestamp: Date.now()
            };
            if (!ad.title || !ad.mediaUrl) { showStatus('Title and Media URL required.', 'error'); return; }
            if (editId) {
                database.ref('ads/' + editId).update(ad)
                    .then(() => { showStatus('Ad updated!', 'success'); clearAdForm(); })
                    .catch(err => showStatus('Error: ' + err.message, 'error'));
            } else {
                database.ref('ads').push(ad)
                    .then(() => { showStatus('Ad created!', 'success'); clearAdForm(); })
                    .catch(err => showStatus('Error: ' + err.message, 'error'));
            }
        }

        function loadAds() {
            const container = document.getElementById('ads-grid-container');
            database.ref('ads').orderByChild('timestamp').on('value', snapshot => {
                container.innerHTML = '';
                if (!snapshot.exists()) {
                    container.innerHTML = '<p style="color:var(--text-secondary)">No ads found.</p>';
                    return;
                }
                snapshot.forEach(child => {
                    const ad = child.val();
                    const key = child.key;
                    const card = document.createElement('div');
                    card.className = 'ad-card';
                    card.innerHTML = `
                        <span class="ad-type-badge"><i class="fa-solid ${ad.type === 'video' ? 'fa-video' : 'fa-image'}"></i> ${ad.type.toUpperCase()}</span>
                        <div class="ad-preview">${ad.type === 'video' ? `<video src="${ad.mediaUrl}" controlsList="nodownload" playsinline></video>` : `<img src="${ad.mediaUrl}" alt="${ad.title}">`}</div>
                        <div class="ad-content"><div class="ad-title">${ad.title}</div><div class="ad-meta"><span><i class="fa-solid fa-clock"></i> ${ad.duration}s</span>${ad.targetUrl ? '<span><i class="fa-solid fa-link"></i> Linked</span>' : ''}</div></div>
                        <div class="ad-controls">
                            <div class="switch-container"><label class="switch"><input type="checkbox" ${ad.isActive ? 'checked' : ''} onchange="toggleAdStatus('${key}', this.checked)"><span class="slider"></span></label></div>
                            <div style="display:flex;gap:8px;">
                                <button class="btn-icon" onclick="editAd('${key}')"><i class="fa-solid fa-pencil"></i></button>
                                <button class="btn-icon" onclick="deleteData('ads', '${key}')"><i class="fa-solid fa-trash"></i></button>
                            </div>
                        </div>`;
                    container.prepend(card);
                });
            });
        }

        function editAd(id) {
            database.ref('ads/' + id).once('value').then(snapshot => {
                const ad = snapshot.val();
                if (!ad) return;
                document.getElementById('ad-edit-id').value = id;
                document.getElementById('save-ad-btn').textContent = 'Update Advertisement';
                document.getElementById('ad-title').value = ad.title || '';
                document.getElementById('ad-type').value = ad.type || 'image';
                document.getElementById('ad-media-url').value = ad.mediaUrl || '';
                document.getElementById('ad-target-url').value = ad.targetUrl || '';
                document.getElementById('ad-duration').value = ad.duration || 5;
                document.getElementById('ad-is-active').checked = ad.isActive || false;
                window.scrollTo({ top: 0, behavior: 'smooth' });
            });
        }

        function toggleAdStatus(key, status) {
            database.ref('ads/' + key).update({ isActive: status })
                .then(() => showStatus('Ad status updated.', 'success'))
                .catch(err => showStatus('Error: ' + err.message, 'error'));
        }

        // ========== REDEEM CODES (ENHANCED) ==========
        function generateRandomCode(length = 10) {
            const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789';
            let code = '';
            for (let i = 0; i < length; i++) code += chars.charAt(Math.floor(Math.random() * chars.length));
            return code;
        }

        function generateRedeemCodes() {
            const days = parseInt(document.getElementById('redeem-days').value);
            const price = document.getElementById('redeem-price').value.trim();
            const count = parseInt(document.getElementById('redeem-count').value);
            const expiry = document.getElementById('redeem-expiry').value;
            const maxUses = parseInt(document.getElementById('redeem-max-uses').value) || 1;

            if (!days || days < 1) { showStatus('Enter valid days.', 'error'); return; }
            if (!price) { showStatus('Enter a price.', 'error'); return; }
            if (!count || count < 1 || count > 50) { showStatus('Count must be 1-50.', 'error'); return; }

            const updates = {};
            for (let i = 0; i < count; i++) {
                const code = generateRandomCode();
                const codeData = {
                    days, price, status: 'available', usedCount: 0, maxUses,
                    createdAt: firebase.database.ServerValue.TIMESTAMP,
                    createdBy: 'Admin'
                };
                if (expiry) codeData.expiryDate = new Date(expiry).getTime();
                updates[`/redeem_codes/${code}`] = codeData;
            }

            database.ref().update(updates)
                .then(() => {
                    showStatus(`${count} code(s) generated!`, 'success');
                    document.getElementById('redeem-days').value = '';
                    document.getElementById('redeem-price').value = '';
                    document.getElementById('redeem-count').value = '1';
                    document.getElementById('redeem-expiry').value = '';
                    document.getElementById('redeem-max-uses').value = '1';
                })
                .catch(err => showStatus('Error: ' + err.message, 'error'));
        }

        function loadRedeemCodes() {
            const tbody = document.getElementById('redeem-codes-body');
            database.ref('redeem_codes').orderByChild('createdAt').on('value', snapshot => {
                tbody.innerHTML = '';
                if (!snapshot.exists()) {
                    tbody.innerHTML = '<tr><td colspan="9" style="text-align:center;">No codes generated yet.</td></tr>';
                    return;
                }
                snapshot.forEach(child => {
                    const code = child.key;
                    const data = child.val();
                    const statusClass = data.status === 'available' ? 'code-available' : 'code-used';
                    const usedDisplay = `${data.usedCount || 0}/${data.maxUses || 1}`;
                    const expiryDisplay = data.expiryDate ? new Date(data.expiryDate).toLocaleDateString() : 'Never';
                    const usedAtDisplay = data.usedAt ? new Date(data.usedAt).toLocaleString() : '-';
                    const usedByDisplay = data.usedBy || '-';
                    
                    const tr = document.createElement('tr');
                    tr.innerHTML = `
                        <td><code>${code}</code></td>
                        <td>${data.days}</td>
                        <td>${data.price || 'N/A'}</td>
                        <td class="${statusClass}">${data.status === 'available' ? 'Available' : 'Used'}</td>
                        <td>${usedDisplay}</td>
                        <td>${expiryDisplay}</td>
                        <td>${usedByDisplay}</td>
                        <td>${usedAtDisplay}</td>
                        <td>${data.status === 'available' ? `<button class="code-delete-btn" onclick="deleteRedeemCode('${code}')"><i class="fa-solid fa-trash"></i></button>` : '-'}</td>`;
                    tbody.prepend(tr);
                });
            });
        }

        function deleteRedeemCode(code) {
            if (confirm('Delete this unused code?')) {
                database.ref('redeem_codes/' + code).remove()
                    .then(() => showStatus('Code deleted.', 'success'))
                    .catch(err => showStatus('Error: ' + err.message, 'error'));
            }
        }
    </script>
</body>
</html>
